<!DOCTYPE html>
<html lang="en">
<body>
    <main id="main" class="main">
        <div class="pagetitle">
            <h1>Dashboard</h1>
        </div><!-- End Page Title -->
        <section class="section dashboard">
            <div class="row">
                <!-- Left side columns -->
                <div class="col-12">
                    <div class="row">

                        <div class="col-xxl-6 col-md-6">
                            <div class="card info-card sales-card">
                                <div class="card-body d-flex justify-content-between align-items-center">
                                    <div>
                                        <h5 class="card-title">QC6 Form</h5>
                                    </div>
                                    <a asp-action="QC6FormCreation" asp-controller="QC6Form" class="arrow-icon"><i class="bi bi-arrow-right"></i></a>
                                </div>
                            </div>
                        </div>
                        <!-- Revenue Card -->
                        <div class="col-xxl-6 col-md-6">
                            <div class="card info-card revenue-card">
                                <div class="card-body d-flex justify-content-between align-items-center">
                                    <div>
                                        <h5 class="card-title">QC7 Form</h5>
                                        <div class="d-flex align-items-center">
                                        </div>
                                    </div>
                                    <a asp-action="QC7FormCreation" asp-controller="QC7Form" class="arrow-icon"><i class="bi bi-arrow-right"></i></a>
                                </div>
                            </div>
                        </div><!-- End Revenue Card -->
                        <!-- Customers Card -->
                        <div class="col-xxl-6 col-xl-6">

                            <div class="card info-card customers-card">
                                <div class="card-body d-flex justify-content-between align-items-center">
                                    <h5 class="card-title">Upload Signed FS</h5>

                                    <div class="d-flex align-items-center">
                                    </div>
                                    <a asp-action="ScheduleEmails" asp-controller="SignedFSForm" class="arrow-icon"><i class="bi bi-arrow-right"></i></a>

                                </div>
                            </div>

                        </div><!-- End Customers Card -->
                        <!-- Customers Card -->
                        <div class="col-xxl-6 col-xl-6">

                            <div class="card info-card customers-card">
                                <div class="card-body d-flex justify-content-between align-items-center">
                                    <h5 class="card-title">QC35 Form</h5>

                                    <div class="d-flex align-items-center">
                                    </div>
                                    <a asp-action="QC35FormCreation" asp-controller="QC35Form" class="arrow-icon"><i class="bi bi-arrow-right"></i></a>

                                </div>
                            </div>
                        </div><!-- End Customers Card -->
                    </div>
                </div><!-- End Left side columns -->
                <div>
                    <button id="chatbot-toggle-btn"><img src="~/img/chatbot-icon.png" alt="Chatbot" /></button>
                    <div class="chatbot-popup" id="chatbot-popup">
                        <div class="chat-header">
                            <span>Chatbot</span>
                            <button id="close-btn">&times;</button>
                        </div>
                        <div id="loader" style="display: none;"></div> <!-- Loading indicator -->
                        <div class="chat-box" id="chat-box"></div>
                        <div class="chat-input">
                            <input type="text" id="user-input" placeholder="Type a message...">
                            <button id="send-btn">Send</button>
                        </div>
                        <div class="copyright">
                            <a href="https://www.thecodinghubs.com/" target="_blank">Build By Coding Hubs © 2024</a>
                        </div>
                    </div>
                </div>
            </div>
        </section><!-- End Section -->
    </main><!-- End Main -->
    @section Scripts {
        @{
            <script src="~/js/chatbot.js"></script>
        }
    }
</body>
</html>