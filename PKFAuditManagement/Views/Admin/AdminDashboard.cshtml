<!DOCTYPE html>
<html lang="en">
    <style>
    /* styles.css */

    /* Chat Widget Styling */
    #chat-widget {
        position: fixed;
        bottom: 0;
        right: 0;
        width: 300px;
        height: 400px;
        background: #fff;
        border: 1px solid #ddd;
        border-radius: 8px;
        display: none;
        flex-direction: column;
    }

    #chat-header {
        display: flex;
        justify-content: space-between;
        padding: 10px;
        background: #007bff;
        color: #fff;
        border-top-left-radius: 8px;
        border-top-right-radius: 8px;
    }

        #chat-header h5 {
            margin: 0;
        }

    #chat-close-btn {
        background: none;
        border: none;
        color: #fff;
        font-size: 20px;
        cursor: pointer;
    }

    #chat-messages {
        flex: 1;
        padding: 10px;
        overflow-y: auto;
    }

    .message {
        margin-bottom: 10px;
    }

    .message-bubble {
        max-width: 80%;
        padding: 10px;
        border-radius: 15px;
        background: #f1f1f1;
    }

    #chat-input {
        display: flex;
        border-top: 1px solid #ddd;
        padding: 10px;
    }

        #chat-input input {
            flex: 1;
            border: 1px solid #ddd;
            border-radius: 15px;
            padding: 5px;
        }

        #chat-input button {
            background: #007bff;
            color: #fff;
            border: none;
            padding: 10px;
            border-radius: 15px;
            cursor: pointer;
        }

    #chat-toggle-btn {
        position: fixed;
        bottom: 10px;
        right: 10px;
        background: #007bff;
        border-radius: 50%;
    }

        #chat-toggle-btn button {
            border: none;
            color: #fff;
            padding: 15px;
            border-radius: 50%;
            cursor: pointer;
            font-size: 18px;
        }

</style>
<body>
    <main id="main" class="main">

        <div class="pagetitle">
            <h1>Dashboard</h1>
        </div><!-- End Page Title -->

        <section class="section dashboard">
            <div class="row">

                <!-- Left side columns -->
                <div class="col-12">
                    <div class="row">

                        <div class="col-xxl-6 col-md-6">
                            <div class="card info-card sales-card">
                                <div class="card-body d-flex justify-content-between align-items-center">
                                    <div>
                                        <h5 class="card-title">QC6 Form</h5>
                                    </div>
                                    <a asp-action="QC6FormCreation" asp-controller="QC6Form" class="arrow-icon"><i class="bi bi-arrow-right"></i></a>
                                </div>
                            </div>
                        </div>
                        <!-- Revenue Card -->
                        <div class="col-xxl-6 col-md-6">
                            <div class="card info-card revenue-card">
                                <div class="card-body d-flex justify-content-between align-items-center">
                                    <div>
                                        <h5 class="card-title">QC7 Form</h5>
                                        <div class="d-flex align-items-center">
                                        </div>
                                    </div>
                                    <a asp-action="QC7FormCreation" asp-controller="QC7Form" class="arrow-icon"><i class="bi bi-arrow-right"></i></a>
                                </div>
                            </div>
                        </div><!-- End Revenue Card -->
                        <!-- Customers Card -->
                        <div class="col-xxl-6 col-xl-6">

                            <div class="card info-card customers-card">
                                <div class="card-body d-flex justify-content-between align-items-center">
                                    <h5 class="card-title">Upload Signed FS</h5>

                                    <div class="d-flex align-items-center">
                                    </div>
                                    <a asp-action="ScheduleEmails" asp-controller="SignedFSForm" class="arrow-icon"><i class="bi bi-arrow-right"></i></a>

                                </div>
                            </div>

                        </div><!-- End Customers Card -->
                        <!-- Customers Card -->
                        <div class="col-xxl-6 col-xl-6">

                            <div class="card info-card customers-card">
                                <div class="card-body d-flex justify-content-between align-items-center">
                                    <h5 class="card-title">QC35 Form</h5>

                                    <div class="d-flex align-items-center">
                                    </div>
                                    <a asp-action="QC35FormCreation" asp-controller="QC35Form" class="arrow-icon"><i class="bi bi-arrow-right"></i></a>

                                </div>
                            </div>
                        </div><!-- End Customers Card -->
                    </div>
                </div><!-- End Left side columns -->
                <!-- Chat Widget -->
                <div id="chat-widget">
                    <div id="chat-header">
                        <h5>Chat with Us</h5>
                        <button id="chat-close-btn">×</button>
                    </div>
                    <div id="chat-messages">
                        <div class="message">
                            <div class="message-bubble">
                                <p>Hello! How can we assist you today?</p>
                            </div>
                        </div>
                        <!-- More messages can be added here -->
                    </div>
                    <div id="chat-input">
                        <input id="user-message" type="text" placeholder="Type your message...">
                        <button id="send-btn">Send</button>
                    </div>
                </div>
            </div>
        </section>
    </main><!-- End #main -->

    <!-- Floating Button to Open Chat -->
    <div id="chat-toggle-btn">
        <button class="btn btn-primary chat-button" onclick="toggleChat()">Chat</button>
    </div>
</body>

</html>

<script>
    // JavaScript to handle chat widget visibility
    function toggleChat() {
        const chatWidget = document.getElementById('chat-widget');
        const chatToggleBtn = document.getElementById('chat-toggle-btn');

        if (chatWidget.style.display === 'flex') {
            chatWidget.style.display = 'none';
            chatToggleBtn.style.display = 'flex'; // Ensure toggle button is visible
        } else {
            chatWidget.style.display = 'flex';
            chatToggleBtn.style.display = 'none'; // Hide toggle button when chat is open
        }
    }

    document.getElementById('chat-close-btn').addEventListener('click', function () {
        const chatWidget = document.getElementById('chat-widget');
        const chatToggleBtn = document.getElementById('chat-toggle-btn');
        chatWidget.style.display = 'none';
        chatToggleBtn.style.display = 'flex'; // Show toggle button when chat is closed
    });

    document.addEventListener('DOMContentLoaded', () => {
        const sendButton = document.getElementById('send-btn');
        const userMessageInput = document.getElementById('user-message');
        const chatMessages = document.getElementById('chat-messages');

        sendButton.addEventListener('click', async () => {
            const userInput = userMessageInput.value;
            alert(userInput);
            if (userInput.trim() === '') return;

            // Append user message to chat
            addMessage('user-message', userInput);
            userMessageInput.value = '';

            // Make AJAX request
            $.ajax({
                url: '/Chatbot/GetChatResponse',
                type: 'POST',
                data: { 'userInput': userInput },
                success: function (response) {
                    // Append bot response to chat
                    addMessage('bot-message', response.response);
                },
                error: function (xhr, status, error) {
                    console.error('Error:', error);
                }
            });
        });

        function addMessage(sender, message) {
            const messageDiv = document.createElement('div');
            messageDiv.className = 'message';
            messageDiv.innerHTML = `
                <div class="message-bubble ${sender}">
                    <p>${message}</p>
                </div>
            `;
            chatMessages.appendChild(messageDiv);
            chatMessages.scrollTop = chatMessages.scrollHeight; // Scroll to bottom
        }
    });
</script>
