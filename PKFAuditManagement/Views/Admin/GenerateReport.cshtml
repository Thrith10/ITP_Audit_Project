        <script>
        async function generateReport() {
            // Collect selected fields
            let selectedFields = [];
            if (document.getElementById('chkProspectiveClient').checked) selectedFields.push('ProspectiveClient');
            if (document.getElementById('chkPeriodEnded').checked) selectedFields.push('PeriodEnded');
            if (document.getElementById('chkEngagementType').checked) selectedFields.push('EngagementType');
            if (document.getElementById('chkNatureOfServiceForEstimateFee').checked) selectedFields.push('NatureOfServiceForEstimateFee');
            if (document.getElementById('chkBudgetedFeeRecoveryRate').checked) selectedFields.push('BudgetedFeeRecoveryRate');
            if (document.getElementById('chkComplexityOfEngagement').checked) selectedFields.push('ComplexityOfEngagement');

            if (selectedFields.length > 0) 
            {
                const queryRequest = { SelectedFields: selectedFields };
                console.log('Query Request:', queryRequest); // Log the request to ensure it's correct

                try {
                    const response = await fetch('/api/report/GenerateReport', {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify(queryRequest)
                    });

                    if (!response.ok) {
                        const errorText = await response.text();
                        throw new Error(errorText);
                    }

                    // Create a blob from the response
                    const blob = await response.blob();
                    // Create a link element to download the file
                    const link = document.createElement('a');
                    link.href = window.URL.createObjectURL(blob);
                    link.download = 'Report.xlsx';
                    link.click();
                    //console.log('Report Data:', data);
                    
                } catch (error) {
                    console.error('Error generating report:', error);
                    alert(`Error generating report: ${error.message}`);
                }

            } else {
                alert('Please select at least one field.');
            }
        }
    </script>

</body>

</html>