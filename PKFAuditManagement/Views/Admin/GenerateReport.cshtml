<!DOCTYPE html>
<html lang="en">
<body>
    <main id="main" class="main">

        <div class="pagetitle">
            <h1>Generate Report</h1>
            <nav>
                <ol class="breadcrumb">
                    <li class="breadcrumb-item"><a href="index.html">Admin</a></li>
                    <li class="breadcrumb-item">GenerateReport</li>
                </ol>
            </nav>
        </div><!-- End Page Title -->

        <section class="section">
            <div class="row">
                <div class="col-lg-12">

                    <div class="card">
                        <div class="card-body">
                            <h5 class="card-title">Reports</h5>
                            <p>Select which user to generate a report.</p>
                            
                            <!-- Form with checkboxes -->
                            <form id="reportForm">
                                <div class="form-check">
                                    <input class="form-check-input" type="checkbox" value="" id="chkProspectiveClient">
                                    <label class="form-check-label" for="chkProspectiveClient">
                                        Prospective Client
                                    </label>
                                </div>
                                <div class="form-check">
                                    <input class="form-check-input" type="checkbox" value="" id="chkPeriodEnded">
                                    <label class="form-check-label" for="chkPeriodEnded">
                                        Period Ended
                                    </label>
                                </div>
                                <div class="form-check">
                                    <input class="form-check-input" type="checkbox" value="" id="chkEngagementType">
                                    <label class="form-check-label" for="chkEngagementType">
                                        Engagement Type
                                    </label>
                                </div>
                                <div class="form-check">
                                    <input class="form-check-input" type="checkbox" value="" id="chkNatureOfServiceForEstimateFee">
                                    <label class="form-check-label" for="chkNatureOfServiceForEstimateFee">
                                        Nature of Service for Estimate Fee
                                    </label>
                                </div>
                                <div class="form-check">
                                    <input class="form-check-input" type="checkbox" value="" id="chkBudgetedFeeRecoveryRate">
                                    <label class="form-check-label" for="chkBudgetedFeeRecoveryRate">
                                        Budgeted Fee Recovery Rate
                                    </label>
                                </div>
                                <div class="form-check">
                                    <input class="form-check-input" type="checkbox" value="" id="chkComplexityOfEngagement">
                                    <label class="form-check-label" for="chkComplexityOfEngagement">
                                        Complexity of Engagement
                                    </label>
                                </div>

                                <button type="button" class="btn btn-primary mt-3" onclick="generateReport()">Generate Report</button>
                            </form>

                        </div>
                        
                    </div>

                </div>
            </div>
        </section>

    </main><!-- End #main -->
    <!-- ======= Footer ======= -->
