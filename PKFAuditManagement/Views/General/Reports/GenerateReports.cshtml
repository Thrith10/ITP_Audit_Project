@model IEnumerable<PKFAuditManagement.ViewModels.ReportsViewModel>

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Generate Reports</title>
    <link rel="stylesheet" href="~/css/site.css">
    <!-- Additional styles or scripts if needed -->
    <style>
        .next-button {
            position: fixed;
            bottom: 20px;
            right: 20px;
        }

        .form-checkboxes {
            display: none;
            margin-top: 20px;
        }

            .form-checkboxes label {
                display: block;
                margin-bottom: 10px;
            }
    </style>
</head>
<body>
    <main id="main" class="main">
        <div class="pagetitle">
            <h1>Generate Reports</h1>
        </div><!-- End Page Title -->

        <section class="section">
            <div class="row">
                <div class="col-lg-12">

                    <div class="card">
                        <div class="card-body">
                            <div class="row">
                                <div class="col-6">
                                    <h5 class="card-title">Generate Reports</h5>
                                </div>
                                <div class="col-6 mt-3 text-end">
                                    <!-- Placeholder for a button or link if needed -->
                                    <!-- Remove the Create Report button -->
                                </div>
                            </div>

                            <!-- Dropdown for selecting form type -->
                            <div class="mb-3" id="formTypeContainer">
                                <label for="formType" class="form-label">Select Form Type:</label>
                                <select id="formType" class="form-select" onchange="filterForms()">
                                    <option value="QC6" selected>QC6 Forms</option>
                                    <option value="QC7">QC7 Forms</option>
                                </select>
                            </div>

                            <!-- Table to display report data -->
                            <table class="table datatable" id="reportTable">
                                <thead>
                                    <tr>
                                        <th>Select</th>
                                        <th>Form ID</th>
                                        <th>File Reference</th>
                                        <th>Prospective Client</th>
                                        <th>Period Ended</th>
                                        <th>Type of Engagement</th>
                                        <th>Form Submission Date</th>
                                        <th>Prepared By Date</th>
                                        <th>Status</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @if (Model.Any())
                                    {
                                        foreach (var form in Model)
                                        {
                                            if (form.QC6FormID != 0) // Check if it's a QC6 form
                                            {
                                                <tr id="@form.QC6FormID" class="qc6-form">
                                                    <td>
                                                        <!-- Checkbox for selecting the form -->
                                                        <input type="checkbox" name="selectedForms" value="@form.QC6FormID" />
                                                    </td>
                                                    <td>@form.QC6FormID</td>
                                                    <td>@form.FileReference</td>
                                                    <td>@form.ProspectiveClient</td>
                                                    <td>@form.PeriodEnded.ToShortDateString()</td>
                                                    <td>@form.EngagementType</td>
                                                    <td>@form.FormSubmissionDate.ToShortDateString()</td>
                                                    <td>@form.PreparedByDate.ToShortDateString()</td>
                                                    <td>
                                                        @if (form.Status == "Pending")
                                                        {
                                                            <span class="badge bg-warning">Pending</span>
                                                        }
                                                        else if (form.Status == "Pending 2nd Approval")
                                                        {
                                                            <span class="badge bg-warning">Pending 2nd Approval</span>
                                                        }
                                                        else if (form.Status == "Approved")
                                                        {
                                                            <span class="badge bg-success">Approved</span>
                                                        }
                                                        else if (form.Status == "Rejected")
                                                        {
                                                            <span class="badge bg-danger">Rejected</span>
                                                        }
                                                        else
                                                        {
                                                            <span class="badge bg-secondary">@form.Status</span>
                                                        }
                                                    </td>
                                                </tr>
                                            }
                                            else if (form.QC7FormID != 0) // Check if it's a QC7 form
                                            {
                                                <tr id="@form.QC7FormID" class="qc7-form" style="display: none;">
                                                    <td>
                                                        <!-- Checkbox for selecting the form -->
                                                        <input type="checkbox" name="selectedForms" value="@form.QC7FormID" />
                                                    </td>
                                                    <td>@form.QC7FormID</td>
                                                    <td>@form.FileReference</td>
                                                    <td>@form.ProspectiveClient</td>
                                                    <td>@form.PeriodEnded.ToShortDateString()</td>
                                                    <td>@form.EngagementType</td>
                                                    <td>@form.FormSubmissionDate.ToShortDateString()</td>
                                                    <td>@form.PreparedByDate.ToShortDateString()</td>
                                                    <td>
                                                        @if (form.Status == "Pending")
                                                        {
                                                            <span class="badge bg-warning">Pending</span>
                                                        }
                                                        else if (form.Status == "Pending 2nd Approval")
                                                        {
                                                            <span class="badge bg-warning">Pending 2nd Approval</span>
                                                        }
                                                        else if (form.Status == "Approved")
                                                        {
                                                            <span class="badge bg-success">Approved</span>
                                                        }
                                                        else if (form.Status == "Rejected")
                                                        {
                                                            <span class="badge bg-danger">Rejected</span>
                                                        }
                                                        else
                                                        {
                                                            <span class="badge bg-secondary">@form.Status</span>
                                                        }
                                                    </td>
                                                </tr>
                                            }
                                        }
                                    }
                                    else
                                    {
                                        <tr><td colspan="9">No data found.</td></tr>
                                    }
                                </tbody>
                            </table>

                            <!-- Form with checkboxes -->
                            <form id="checkboxForm" class="form-checkboxes">
                                <div class="mb-3">
                                    <label><input type="checkbox" name="prospectiveClient" value="Prospective Client"> Prospective Client</label>
                                    <label><input type="checkbox" name="periodEnded" value="Period Ended"> Period Ended</label>
                                    <label><input type="checkbox" name="engagementType" value="Engagement Type"> Engagement Type</label>
                                    <label><input type="checkbox" name="natureOfService" value="Nature of Service for Estimate Fee"> Nature of Service for Estimate Fee</label>
                                    <label><input type="checkbox" name="budgetedFee" value="Budgeted Fee Recovery Rate"> Budgeted Fee Recovery Rate</label>
                                    <label><input type="checkbox" name="complexityOfEngagement" value="Complexity of Engagement"> Complexity of Engagement</label>
                                </div>
                                <button type="submit" class="btn btn-primary">Generate Report</button>
                            </form>

                        </div>
                    </div>

                </div>
            </div>
        </section>

    </main><!-- End #main -->
    <!-- Next button -->
    <button type="button" class="btn btn-primary next-button" onclick="showCheckboxForm()">Next</button>

    <!-- Optional: Footer section -->
    <!--
    <footer id="footer" class="footer">
        <div class="copyright">
            &copy; Copyright <strong><span>NiceAdmin</span></strong>. All Rights Reserved
        </div>
        <div class="credits">
            Designed by <a href="https://bootstrapmade.com/">BootstrapMade</a>
        </div>
    </footer>
    -->
    <!-- Scripts section -->
    @section Scripts {
        <!-- Include any necessary scripts -->
        <script src="~/js/qc6-form-management-admin.js"></script>

        <!-- JavaScript function to handle form type change -->
        <script>
            function filterForms() {
                var formType = document.getElementById("formType").value;
                var qc6Forms = document.querySelectorAll(".qc6-form");
                var qc7Forms = document.querySelectorAll(".qc7-form");

                if (formType === "QC6") {
                    qc6Forms.forEach(function (form) {
                        form.style.display = "";
                    });
                    qc7Forms.forEach(function (form) {
                        form.style.display = "none";
                    });
                } else if (formType === "QC7") {
                    qc6Forms.forEach(function (form) {
                        form.style.display = "none";
                    });
                    qc7Forms.forEach(function (form) {
                        form.style.display = "";
                    });
                }
            }

            function showCheckboxForm() {
                var table = document.getElementById("reportTable");
                var checkboxForm = document.getElementById("checkboxForm");
                var checkboxes = document.querySelectorAll('input[type="checkbox"][name="selectedForms"]:checked');

                if (checkboxes.length === 0) {
                    alert("Please select at least one form.");
                    return;
                }

                table.style.display = "none"; // Hide the table
                checkboxForm.style.display = "block"; // Show the checkbox form
                document.querySelector('.next-button').style.display = "none"; // Hide the Next button
                document.getElementById('formTypeContainer').style.display = "none"; // Hide the form type dropdown
            }
        </script>
    }
</body>
</html>
