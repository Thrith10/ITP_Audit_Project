@model IEnumerable<PKFAuditManagement.ViewModels.ReportsViewModel>

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Generate Reports</title>
    <link rel="stylesheet" href="~/css/site.css">
    <link rel="stylesheet" href="https://cdn.datatables.net/1.13.4/css/jquery.dataTables.min.css">
    <style>
        .next-button {
            position: fixed;
            bottom: 20px;
            right: 20px;
        }

        .form-checkboxes {
            display: none;
            margin-top: 20px;
        }

            .form-checkboxes label {
                display: block;
                margin-bottom: 10px;
            }

        .date-filter {
            margin-bottom: 20px;
            display: flex;
            gap: 10px;
            align-items: center;
        }

            .date-filter input {
                margin-right: 10px;
            }

        .hidden {
            display: none;
        }

        /* Hide the Form ID column */
        #reportTable th:nth-child(2),
        #reportTable td:nth-child(2) {
            display: none;
        }
    </style>
</head>
<body>
    <main id="main" class="main">
        <div class="pagetitle">
            <h1>Generate Reports</h1>
        </div><!-- End Page Title -->

        <section class="section">
            <div class="row">
                <div class="col-lg-12">
                    <div class="card">
                        <div class="card-body">
                            <div class="row">
                                <div class="col-6">
                                    <h5 class="card-title">Generate Reports</h5>
                                </div>
                                <div class="col-6 mt-3 text-end">
                                    <!-- Placeholder for a button or link if needed -->
                                </div>
                            </div>

                            <!-- Dropdown for selecting form type -->
                            <div class="mb-3" id="formTypeContainer">
                                <label for="formType" class="form-label">Select Form Type:</label>
                                <select id="formType" class="form-select" onchange="filterForms()">
                                    <option value="QC6" selected>QC6 Forms</option>
                                    <option value="QC7">QC7 Forms</option>
                                    <option value="QC35">QC35 Forms</option>
                                    <option value="SignedFS">Signed Financial Statements</option>
                                    <option value="ClientStatus">Client Status</option> <!-- New option -->
                                </select>
                            </div>

                            <!-- Date filter -->
                            <div class="date-filter" id="dateFilterContainer">
                                <label for="startDate">Start Date:</label>
                                <input type="date" id="startDate">
                                <label for="endDate">End Date:</label>
                                <input type="date" id="endDate">
                                <button class="btn btn-primary" onclick="filterByDate()">Filter</button>
                                <button class="btn btn-secondary" onclick="clearFilters()">Clear Filters</button>
                            </div>

                            <!-- Table to display report data -->
                            <table class="table datatable" id="reportTable">
                                <thead>
                                    <!-- QC6 Headers -->
                                    <tr class="qc6-header">
                                        <th><input type="checkbox" id="selectAllQc6" /> Select All</th>
                                        <th>Form ID</th>
                                        <th>File Reference</th>
                                        <th>Client</th>
                                        <th>Period Ended</th>
                                        <th>Engagement Type</th>
                                        <th>Prepared By Date</th>
                                        <th>Form Submission Date</th> <!-- New column for MPHOD QMP Approved By Date -->
                                        <th>Status</th>
                                    </tr>
                                    <!-- QC7 Headers -->
                                    <tr class="qc7-header" style="display: none;">
                                        <th><input type="checkbox" id="selectAllQc7" /> Select All</th>
                                        <th>Form ID</th>
                                        <th>Client</th>
                                        <th>Engagement Type</th>
                                        <th>Period Ended</th>
                                        <th>Prepared By Date</th>
                                        <th>Form Submission Date</th>
                                        <th>Status</th>
                                    </tr>
                                    <!-- QC35 Headers -->
                                    <tr class="qc35-header" style="display: none;">
                                        <th><input type="checkbox" id="selectAllQc35" /> Select All</th>
                                        <th>Form ID</th>
                                        <th>Client Name</th>
                                        <th>Partner Name</th>
                                        <th>Reporting Year End</th>
                                        <th>Manager Name</th>
                                        <th>Status</th>
                                    </tr>
                                    <!-- SignedFS Headers -->
                                    <tr class="signedfs-header" style="display: none;">
                                        <th><input type="checkbox" id="selectAllSignedFS" /> Select All</th>
                                        <th>Form ID</th>
                                        <th>User Email</th>
                                        <th>Partner Email</th>
                                        <th>Client</th>
                                        <th>Year-End Date</th>
                                        <th>Audit Report Date</th>
                                        <th>Status</th>
                                    </tr>
                                    <!-- ClientStatus Headers -->
                                    <tr class="clientstatus-header" style="display: none;">
                                        <th><input type="checkbox" id="selectAllClientStatus" /> Select All</th>
                                        <th>CSClientName</th>
                                        <th>Client Name</th>
                                        <th>Client Financial Year End</th>
                                        <th>QC6 First Approver</th>
                                        <th>QC6 Second Approver</th>
                                        <th>QC7 First Approver</th>
                                        <th>QC7 Second Approver</th>
                                        <th>QC6 Status</th>
                                        <th>QC7 Status</th>
                                        <th>QC35 Status</th>
                                        <th>SignedFS Status</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @if (Model.Any())
                                    {
                                        foreach (var form in Model)
                                        {
                                            if (form.FormType == "QC6")
                                            {
                                                <tr id="@form.QC6FormID" class="qc6-form">
                                                    <td><input type="checkbox" name="selectedForms" value="@form.QC6FormID" class="selectQc6" /></td>
                                                    <td>@form.QC6FormID</td>
                                                    <td>@form.FileReference</td>
                                                    <td>@form.ProspectiveClient</td>
                                                    <td>@form.PeriodEnded.ToShortDateString()</td>
                                                    <td>@form.EngagementType</td>
                                                    <td>@form.PreparedByDate.ToShortDateString()</td>
                                                    <td>@form.MPHODQMPApprovedByDate?.ToShortDateString()</td>
                                                    <td>@form.Status</td>
                                                </tr>
                                            }
                                            else if (form.FormType == "QC7")
                                            {
                                                <tr id="@form.QC7FormID" class="qc7-form" style="display: none;">
                                                    <td><input type="checkbox" name="selectedForms" value="@form.QC7FormID" class="selectQc7" /></td>
                                                    <td>@form.QC7FormID</td>
                                                    <td>@form.ProspectiveClient</td>
                                                    <td>@form.EngagementType</td>
                                                    <td>@form.PeriodEnded.ToShortDateString()</td>
                                                    <td>@form.PreparedByDate.ToShortDateString()</td>
                                                    <td>@form.MPHODQMPApprovedByDate?.ToShortDateString()</td>
                                                    <td>@form.Status</td>
                                                </tr>
                                            }
                                            else if (form.FormType == "QC35")
                                            {
                                                <tr id="@form.QC35FormID" class="qc35-form" style="display: none;">
                                                    <td><input type="checkbox" name="selectedForms" value="@form.QC35FormID" class="selectQc35" /></td>
                                                    <td>@form.QC35FormID</td>
                                                    <td>@form.ClientName</td>
                                                    <td>@form.PartnerName</td>
                                                    <td>@form.ReportingYearEnd?.ToShortDateString()</td>
                                                    <td>@form.ManagerName</td>
                                                    <td>@form.Status</td>
                                                </tr>
                                            }
                                            else if (form.FormType == "SignedFS")
                                            {
                                                <tr id="@form.SignedFSFormID" class="signedfs-form" style="display: none;">
                                                    <td><input type="checkbox" name="selectedForms" value="@form.SignedFSFormID" class="selectSignedFS" /></td>
                                                    <td>@form.SignedFSFormID</td>
                                                    <td>@form.UserEmail</td>
                                                    <td>@form.PartnerEmail</td>
                                                    <td>@form.Client</td>
                                                    <td>@form.ScheduleDate?.ToShortDateString()</td>
                                                    <td>@form.AuditedReportDate?.ToShortDateString()</td>
                                                    <td>@form.IsProcessed</td>
                                                </tr>
                                            }
                                            else if (form.FormType == "ClientStatus")
                                            {
                                                <tr id="@form.CSClientName" class="clientstatus-form" style="display: none;">
                                                    <td><input type="checkbox" name="selectedForms" value="@form.CSClientName" class="selectClientStatus" /></td>
                                                    <td>@form.CSClientName</td>
                                                    <td>@form.CSClientName</td>
                                                    <td>@form.ClientStatusFinancialYearEnd?.ToShortDateString()</td>
                                                    <td>@form.QC6FirstApprover</td>
                                                    <td>@form.QC6SecondApprover</td>
                                                    <td>@form.QC7FirstApprover</td>
                                                    <td>@form.QC7SecondApprover</td>
                                                    <td>@form.QC6Status</td>
                                                    <td>@form.QC7Status</td>
                                                    <td>@form.QC35Status</td>
                                                    <td>@form.SignedFSStatus</td>
                                                </tr>
                                            }
                                        }
                                    }
                                    else
                                    {
                                        <tr>
                                            <td colspan="8" class="text-center">No forms found.</td>
                                        </tr>
                                    }
                                </tbody>
                            </table>

                            <!-- Form with checkboxes -->
                            <form id="checkboxFieldsForm" onsubmit="generateReport(event)"></form>

                            <button class="btn btn-primary next-button" onclick="showCheckboxForm()">Next</button>
                        </div>
                    </div>
                </div>
            </div>
        </section>
    </main><!-- End #main -->

    <script src="https://code.jquery.com/jquery-3.6.4.min.js"></script>
    <script src="https://cdn.datatables.net/1.13.4/js/jquery.dataTables.min.js"></script>
    <script>
        $(document).ready(function () {
            $('#reportTable').DataTable({
                paging: true,
                searching: false,
                ordering: true,
                info: true
            });

            // Initialize by applying filters to show only the selected form type
            filterForms();
        });

        $(document).ready(function () {
            // Select or Deselect All QC6 Checkboxes
            $('#selectAllQc6').on('change', function () {
                $('.selectQc6').prop('checked', this.checked); // Check or uncheck all QC6 checkboxes
            });

            // Select or Deselect All QC7 Checkboxes
            $('#selectAllQc7').on('change', function () {
                $('.selectQc7').prop('checked', this.checked); // Check or uncheck all QC7 checkboxes
            });

            // Select or Deselect All QC35 Checkboxes
            $('#selectAllQc35').on('change', function () {
                $('.selectQc35').prop('checked', this.checked); // Check or uncheck all QC35 checkboxes
            });

            // Select or Deselect All SignedFS Checkboxes
            $('#selectAllSignedFS').on('change', function () {
                $('.selectSignedFS').prop('checked', this.checked); // Check or uncheck all SignedFS checkboxes
            });

            // Select or Deselect All Client Status Checkboxes
            $('#selectAllClientStatus').on('change', function () {
                $('.selectClientStatus').prop('checked', this.checked); // Check or uncheck all Client Status checkboxes
            });
        });

        function filterForms() {
            var formType = document.getElementById("formType").value;

            var qc6Forms = document.querySelectorAll(".qc6-form");
            var qc7Forms = document.querySelectorAll(".qc7-form");
            var qc35Forms = document.querySelectorAll(".qc35-form");
            var signedFSForms = document.querySelectorAll(".signedfs-form");
            var clientStatusForms = document.querySelectorAll(".clientstatus-form");

            var headers = {
                qc6: document.querySelectorAll(".qc6-header"),
                qc7: document.querySelectorAll(".qc7-header"),
                qc35: document.querySelectorAll(".qc35-header"),
                signedfs: document.querySelectorAll(".signedfs-header"),
                clientstatus: document.querySelectorAll(".clientstatus-header") // ClientStatus header
            };

            // Hide all headers initially
            Object.values(headers).forEach(header => {
                header.forEach(h => h.style.display = "none");
            });

            // Show header based on selected form type
            if (formType === "QC6") {
                qc6Forms.forEach(function (form) {
                    form.style.display = "";
                });
                headers.qc6.forEach(h => h.style.display = "");
                qc7Forms.forEach(function (form) {
                    form.style.display = "none";
                });
                qc35Forms.forEach(function (form) {
                    form.style.display = "none";
                });
                signedFSForms.forEach(function (form) {
                    form.style.display = "none";
                });
                clientStatusForms.forEach(function (form) {
                    form.style.display = "none";
                });
                document.querySelector('.date-filter').classList.remove('hidden');
            } else if (formType === "QC7") {
                qc6Forms.forEach(function (form) {
                    form.style.display = "none";
                });
                headers.qc7.forEach(h => h.style.display = "");
                qc7Forms.forEach(function (form) {
                    form.style.display = "";
                });
                qc35Forms.forEach(function (form) {
                    form.style.display = "none";
                });
                signedFSForms.forEach(function (form) {
                    form.style.display = "none";
                });
                clientStatusForms.forEach(function (form) {
                    form.style.display = "none";
                });
                document.querySelector('.date-filter').classList.remove('hidden');
            } else if (formType === "QC35") {
                qc6Forms.forEach(function (form) {
                    form.style.display = "none";
                });
                headers.qc35.forEach(h => h.style.display = "");
                qc35Forms.forEach(function (form) {
                    form.style.display = "";
                });
                qc7Forms.forEach(function (form) {
                    form.style.display = "none";
                });
                signedFSForms.forEach(function (form) {
                    form.style.display = "none";
                });
                clientStatusForms.forEach(function (form) {
                    form.style.display = "none";
                });
                document.querySelector('.date-filter').classList.add('hidden');
            } else if (formType === "SignedFS") {
                qc6Forms.forEach(function (form) {
                    form.style.display = "none";
                });
                headers.signedfs.forEach(h => h.style.display = "");
                qc35Forms.forEach(function (form) {
                    form.style.display = "none";
                });
                signedFSForms.forEach(function (form) {
                    form.style.display = "";
                });
                qc7Forms.forEach(function (form) {
                    form.style.display = "none";
                });
                clientStatusForms.forEach(function (form) {
                    form.style.display = "none";
                });
                document.querySelector('.date-filter').classList.add('hidden');
            } else if (formType === "ClientStatus") {
                qc6Forms.forEach(function (form) {
                    form.style.display = "none";
                });
                headers.clientstatus.forEach(h => h.style.display = "");
                qc35Forms.forEach(function (form) {
                    form.style.display = "none";
                });
                signedFSForms.forEach(function (form) {
                    form.style.display = "none";
                });
                qc7Forms.forEach(function (form) {
                    form.style.display = "none";
                });
                clientStatusForms.forEach(function (form) {
                    form.style.display = "";
                });
                document.querySelector('.date-filter').classList.add('hidden'); // Hide date filter for Client Status
            }
        }

        function parseDate(dateStr) {
            if (!dateStr) return null;

            var parts = dateStr.split('/');
            if (parts.length === 3) {
                return new Date(parts[2], parts[1] - 1, parts[0]); // DD/MM/YYYY format
            }

            parts = dateStr.split('-');
            if (parts.length === 3) {
                return new Date(parts[0], parts[1] - 1, parts[2]); // YYYY-MM-DD format
            }

            return new Date(dateStr); // Fallback to default parsing
        }

        function filterByDate() {
            var startDate = new Date(document.getElementById("startDate").value);
            var endDate = new Date(document.getElementById("endDate").value);
            var rows = document.querySelectorAll("#reportTable tbody tr");

            rows.forEach(function (row) {
                var preparedByDateStr = row.cells[6].textContent.trim();
                var preparedByDate = parseDate(preparedByDateStr);
                var isFormTypeMatch = row.classList.contains("qc6-form") || row.classList.contains("qc7-form");

                var dateRangeValid = false;
                if (startDate && endDate) {
                    dateRangeValid = (preparedByDate >= startDate && preparedByDate <= endDate);
                } else if (startDate) {
                    dateRangeValid = (preparedByDate >= startDate);
                } else if (endDate) {
                    dateRangeValid = (preparedByDate <= endDate);
                } else {
                    dateRangeValid = true; // If no date range is specified, always valid
                }

                if (preparedByDate && !isNaN(preparedByDate) && dateRangeValid && isFormTypeMatch) {
                    row.style.display = "";
                } else {
                    row.style.display = "none";
                }
            });

            $('#reportTable').DataTable().draw(); // Redraw the DataTable to reflect changes
        }

        function clearFilters() {
            document.getElementById("startDate").value = '';
            document.getElementById("endDate").value = '';
            filterForms();
            $('#reportTable').DataTable().draw();
        }



        function showCheckboxForm() {
            var table = document.getElementById("reportTable");
            var checkboxForm = document.getElementById("checkboxForm");
            var checkboxes = document.querySelectorAll('input[type="checkbox"][name="selectedForms"]:checked');

            if (checkboxes.length === 0) {
                alert("Please select at least one form.");
                return;
            }

            function filterFormFields() {
                var selectedFormType = document.getElementById("formType").value;
                console.log('Selected form type:', selectedFormType);
                fetch('/api/Report/SelectFields')
                    .then(response => response.json())
                    .then(fields => {
                        // Filter the fields based on the selected form type
                        const filteredFields = fields.filter(field => field.section.startsWith(selectedFormType));
                        const form = document.getElementById('checkboxFieldsForm');
                        form.innerHTML = ''; // Clear the form

                        let formHeader = false;
                        let formConclusionHeader = false;

                        const header = document.createElement('h2');
                        header.innerText = 'Select Fields to Include in the Report';
                        form.appendChild(header);

                        // Add a "Select All" checkbox
                        const selectAllDiv = document.createElement('div');
                        selectAllDiv.classList.add('form-group');

                        const selectAllCheckbox = document.createElement('input');
                        selectAllCheckbox.type = 'checkbox';
                        selectAllCheckbox.id = 'selectAllCheckbox';
                        selectAllCheckbox.name = 'selectAllCheckbox';

                        const selectAllLabel = document.createElement('label');
                        selectAllLabel.htmlFor = 'selectAllCheckbox';
                        selectAllLabel.innerText = 'Select All Checkboxes';
                        selectAllLabel.style.fontSize = '1.2em'; // Adjust font size as needed
                        selectAllLabel.style.marginLeft = '5px'; // Add some left margin for space
                        // Add a bit of space below the checkbox and label
                        selectAllDiv.style.marginBottom = '10px'; // Adjust margin bottom as needed

                        selectAllDiv.appendChild(selectAllCheckbox);
                        selectAllDiv.appendChild(selectAllLabel);
                        form.appendChild(selectAllDiv);

                        selectAllCheckbox.addEventListener('change', function() {
                            const checkboxes = form.querySelectorAll('input[type="checkbox"][name="selectedFields"]');
                            checkboxes.forEach(checkbox => {
                                checkbox.checked = selectAllCheckbox.checked;
                            });
                        });

                        filteredFields.forEach(field => {
                            console.log('fieldsections:', field.section);

                            if (field.section.startsWith(selectedFormType)) {
                                if (!formHeader && field.section === `${selectedFormType}Forms`) {
                                    const header = document.createElement('h5');
                                    header.innerText = `${selectedFormType}Form`;
                                    form.appendChild(header);
                                    formHeader = true;
                                }

                                if (!formConclusionHeader && field.section === `${selectedFormType}FormConclusions`) {
                                    const header = document.createElement('h5');
                                    header.innerText = `${selectedFormType}Form Conclusion`;
                                    header.style.marginTop = '10px'; // Add some top margin for space
                                    form.appendChild(header);
                                    formConclusionHeader = true;
                                }
                                // Temp fix for SignedFS form
                                if (!formHeader && field.section === `${selectedFormType}Form`) {
                                    const header = document.createElement('h5');
                                    header.innerText = `${selectedFormType}Form`;
                                    form.appendChild(header);
                                    formHeader = true;
                                }

                                const div = document.createElement('div');
                                div.classList.add('form-group');

                                const uniqueFieldName = `${field.section}_${field.fieldName}`;

                                const checkbox = document.createElement('input');
                                checkbox.type = 'checkbox';
                                checkbox.id = uniqueFieldName;
                                checkbox.name = 'selectedFields';
                                checkbox.value = uniqueFieldName;

                                const label = document.createElement('label');
                                label.htmlFor = field.fieldName;
                                label.innerText = field.fieldLabel;
                                label.style.marginLeft = '5px'; // Add some left margin for space

                                div.appendChild(checkbox);
                                div.appendChild(label);

                                form.appendChild(div);

                            }
                        })

                        // Add a button to submit the selected fields
                        const submitButton = document.createElement('button');
                        submitButton.innerText = 'Generate Report';
                        submitButton.classList.add('btn', 'btn-primary');
                        submitButton.addEventListener('click', generateReport);
                        form.appendChild(submitButton);
                    })
            }

            function generateReport() {
                event.preventDefault();
                const selectedFields = Array.from(document.querySelectorAll('input[name="selectedFields"]:checked'))
                                            .map(cb => ({
                                                fieldName: cb.value,
                                                fieldLabel: cb.parentElement.innerText,
                                                section: cb.parentElement.parentElement.querySelector('h5').innerText,
                                                isSelected: cb.checked
                                            }));

                const selectedFormIds = Array.from(document.querySelectorAll('input[name="selectedForms"]:checked'))
                                            .map(cb => cb.value);

                console.log('Selected fields:', selectedFields);
                console.log('Selected form IDs:', selectedFormIds);

                if (selectedFields.length === 0) {
                    alert('Please select at least one field to include in the report.');
                    return;
                }

                const data = {
                    selectedFormIds: selectedFormIds,
                    fields: selectedFields
                };

                console.log("data:", data);

                fetch('/api/Report/GenerateReport', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json'
                    },
                    body: JSON.stringify(data)
                })
                .then(response => response.blob())
                .then(blob => {
                    const url = window.URL.createObjectURL(blob);
                    const a = document.createElement('a');
                    a.style.display = 'none';
                    a.href = url;
                    a.download = 'report.xlsx';
                    document.body.appendChild(a);
                    a.click();
                    window.URL.revokeObjectURL(url);

                    clearCheckboxes();
                    // Show the table
                    table.style.display = "block";
                    // Hide the checkbox form
                    checkboxFieldsForm.style.display = "none";
                    // Show the Next button
                    document.querySelector('.next-button').style.display = "block";
                    // Show the form type dropdown
                    document.getElementById('formTypeContainer').style.display = "block";
                    // Show the date filter
                    document.querySelector('.date-filter').classList.remove('hidden');

                })
                .catch(error => {
                    console.error('Error generating report:', error);
                    alert('An error occurred while generating the report.');
                });
            }            

            table.style.display = "none"; // Hide the table
            checkboxFieldsForm.style.display = "block"; // Show the checkbox form
            document.querySelector('.next-button').style.display = "none"; // Hide the Next button
            document.getElementById('formTypeContainer').style.display = "none"; // Hide the form type dropdown
            document.querySelector('.date-filter').classList.add('hidden'); // Hide the date filter

            filterFormFields();

        }

        function clearCheckboxes() {
            // Clear selectedFields checkboxes
            const selectedFieldsCheckboxes = document.querySelectorAll('input[name="selectedFields"]:checked');
            selectedFieldsCheckboxes.forEach(cb => {
                cb.checked = false;
            });

            // Clear selectedForms checkboxes
            const selectedFormsCheckboxes = document.querySelectorAll('input[name="selectedForms"]:checked');
            selectedFormsCheckboxes.forEach(cb => {
                cb.checked = false;
            });
        }
        
    </script>
</body>
</html>