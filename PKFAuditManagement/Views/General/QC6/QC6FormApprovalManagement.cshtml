@using PKFAuditManagement.Models
@model List<QC6Form>

<!DOCTYPE html>
<html lang="en">
<body>
    <main id="main" class="main">

        <div class="pagetitle">
            <h1>Manage QC6 Form Approvals</h1>
        </div><!-- End Page Title -->

        <section class="section">
            <div class="row">
                <div class="col-lg-12">

                    <div class="card">
                        <div class="card-body">
                            <h5 class="card-title">Handle the Approval or Rejection of QC6 Forms</h5>
                            <p>As an administrator, you will be able to approval or reject submitted QC6 forms.</p>

                            <table class="table datatable" id="engagementTable">
                                <thead>
                                    <tr>
                                        <th>
                                            File Ref.
                                        </th>
                                        <th>Prospective Client</th>
                                        <th>Period Ended</th>
                                        <th>Type of Engagement</th>
                                        <th data-type="date" data-format="DD/MM/YYYY">Form Submission Date</th>
                                        <th>Status</th>
                                        <th>Actions</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @if (Model != null)
                                    {
                                        foreach (var engagement in Model)
                                        {
                                            <tr>
                                                <td>@engagement.FileReference</td>
                                                <td>@engagement.ProspectiveClient</td>
                                                <td>@engagement.PeriodEnded</td>
                                                <td>@engagement.EngagementType</td>
                                                <td>@engagement.FormSubmissionDate</td>
                                                <td>
                                                    @if (engagement.Status == "Pending")
                                                    {
                                                        <span class="badge bg-warning">Pending</span>
                                                    }
                                                    else if (engagement.Status == "Approved")
                                                    {
                                                        <span class="badge bg-success">Approved</span>
                                                    }
                                                    else if (engagement.Status == "Rejected")
                                                    {
                                                        <span class="badge bg-danger">Rejected</span>
                                                    }
                                                    else
                                                    {
                                                        <span class="badge bg-secondary">@engagement.Status</span>
                                                    }
                                                </td>
                                                <td>
                                                    <a asp-controller="QC6Form" asp-action="View" asp-route-id="@engagement.QC6FormID">View</a> |
                                                    <a class="approveLink" href="#" data-engagement-id="@engagement.QC6FormID">Approve</a>
                                                </td>
                                            </tr>
                                        }
                                    }
                                    else
                                    {
                                        <tr><td colspan="7">No data found.</td></tr>
                                    }
                                </tbody>
                            </table>

                        </div>
                    </div>

                </div>
            </div>
        </section>

    </main><!-- End #main -->
    <!-- ======= Footer ======= -->
