@using PKFAuditManagement.ViewModels
@model QC6FormViewModel

<!DOCTYPE html>
<html lang="en">

<body>
    <div class="justify-content-center">
        <main id="main" class="main">
            <div class="pagetitle">
                <h1>Form QC6(3)</h1>
            </div><!-- End Page Title -->
            <section class="section">
                <div class="row">
                    <div class="col-lg-12">
                        <form asp-action="SubmitQC6Form" asp-controller="QC6Form" method="post">
                        @if (!string.IsNullOrEmpty(Model.ErrorMessage))
                        {
                            <div class="alert alert-danger">
                                @Model.ErrorMessage
                            </div>
                        }
                        <div class="card">
                            <div class="card-body">
                                <h5 class="card-title">New engagement / client acceptance checklist</h5>
                                <form>
                                    <div class="row mb-3">
                                        <label for="inputEmail3" class="col-sm-2 col-form-label">File Reference: D3.3</label>
                                    </div>
                                    <div class="row mb-3">
                                        <label asp-for="ProspectiveClient" class="col-sm-2 col-form-label">Prospective Client:</label>
                                        <div class="col-sm-10">
                                            <input type="text" class="form-control" asp-for="ProspectiveClient">
                                            <span asp-validation-for="ProspectiveClient" class="text-danger"></span>
                                        </div>
                                    </div>
                                    <div class="row mb-3">
                                        <label for="inputEmail3" class="col-sm-2 col-form-label">Period Ended:</label>
                                        <div class="col-sm-10">
                                                <input type="date" class="form-control" asp-for="PeriodEnded">
                                        </div>
                                    </div>
                                    <div class="row mb-3">
                                        <label asp-for="EngagementType" class="col-sm-2 col-form-label">Type of Engagement:</label>
                                        <div class="col-sm-10">
                                            <input type="text" class="form-control" asp-for="EngagementType">
                                            <span asp-validation-for="EngagementType" class="text-danger"></span>
                                        </div>
                                    </div>
                                    <div class="row mb-3">
                                        <div class="col-sm-2">
                                            <strong>Prepared by:</strong>
                                        </div>
                                        <div class="col">
                                            <input type="file" name="uploadedPreparedSignature" id="uploadedPreparedSignature" style="display:none;" />
                                            <label for="uploadedPreparedSignature" class="link-text">Upload Signature</label>
                                        </div>
                                        <div class="col">
                                            <input type="date" class="form-control">
                                        </div>
                                    </div>
                                    <div class="row">
                                        <div class="col-sm-2">
                                            <strong>Reviewed by:</strong>
                                        </div>
                                        <div class="col">
                                            <input type="file" name="uploadedReviewedSignature" id="uploadedReviewedSignature" style="display:none;" />
                                            <label for="uploadedReviewedSignature" class="link-text">Upload Signature</label>
                                        </div>
                                        <div class="col">
                                            <input type="date" class="form-control">
                                        </div>
                                    </div>
                                    <br>
                                    <hr class="my-4">
                                    <div class="row mb-3">
                                        <label class="col-sm-2 col-form-label">Name of PKF entity proposing for the service</label>
                                        <div class="col-sm-10">
                                            <input type="text" class="form-control">
                                        </div>
                                    </div>

                                    <div class="row mb-3">
                                        <label class="col-sm-2 col-form-label">Source of referral of prospective client</label>
                                        <div class="col-sm-10">
                                            <input type="text" class="form-control">
                                        </div>
                                    </div>

                                    <div class="row mb-3">
                                        <label class="col-sm-2 col-form-label">Estimate of fee for this new prospective client (indicate the nature of services)</label>
                                        <div class="col-sm-10">
                                            <input type="text" class="form-control">
                                        </div>
                                    </div>

                                    <div class="row mb-3">
                                        <label class="col-sm-2 col-form-label" data-bs-toggle="tooltip" data-bs-placement="bottom" title="Should at least be 30%.  And to disclose reasons for acceptance if the budgeted fee recovery percentage is below 30%.">
                                            <span class="link-text">Budgeted fee recovery rate (budgeted fee / budgeted time cost)</span>
                                        </label>
                                        <div class="col-sm-10">
                                            <input type="text" class="form-control">
                                        </div>
                                    </div>

                                    <div class="row mb-3">
                                        <label class="col-sm-2 col-form-label">Fee from tax services, accounting, payroll, secretarial services and other non-audit services (if any)</label>
                                        <div class="col-sm-10">
                                            <input type="text" class="form-control">
                                        </div>
                                    </div>

                                    <div class="row mb-3">
                                        <label class="col-sm-2 col-form-label">Any outstanding unpaid fees?</label>
                                        <div class="col-sm-10">
                                            <input class="form-check-input" type="checkbox" id="gridCheck1">
                                        </div>
                                    </div>
                                    <div class="row mb-3">
                                        <label class="col-sm-2 col-form-label" data-bs-toggle="tooltip" data-bs-placement="bottom" title="To calculate before providing non-audit services (“NAS”) to disclose promptly to TCWG if the 50% threshold is crossed.
                                        Computed as % of NAS from client and its controlled entities (excluding ARS fees) over fees from audit of the financial statements from client and its controlled entities.">
                                            <span class="link-text">Fee concentration (Non-audit services fees / audit fees = x%)</span>
                                        </label>
                                        <div class="col-sm-10">
                                            <input type="text" class="form-control">
                                        </div>
                                    </div>
                                    <div class="row mb-3">
                                        <label class="col-sm-2 col-form-label">Conflicts check done?</label>
                                        <div class="col-sm-10">
                                            <input class="form-check-input" type="checkbox" id="gridCheck1">
                                        </div>
                                    </div>

                                    <div class="row mb-3">
                                        <label class="col-sm-2 col-form-label">Type of activities of prospective client</label>
                                        <div class="col-sm-10">
                                            <input type="text" class="form-control">
                                        </div>
                                    </div>

                                    <div class="row mb-3">
                                        <label class="col-sm-2 col-form-label">Complexity of engagement based on preliminary evaluation</label>
                                        <div class="col-sm-10">
                                            <input type="text" class="form-control">
                                        </div>
                                    </div>

                                    <div class="row mb-3">
                                        <label class="col-sm-2 col-form-label">Predecessor Auditor (if applicable)</label>
                                        <div class="col-sm-10">
                                            <input type="text" class="form-control">
                                        </div>
                                    </div>

                                    <div class="row mb-3">
                                        <label class="col-sm-2 col-form-label">Reasons for discontinuance of Predecessor Auditor</label>
                                        <div class="col-sm-10">
                                            <input type="text" class="form-control">
                                        </div>
                                    </div>

                                    <div class="row mb-3">
                                        <label class="col-sm-2 col-form-label">Public Interest Entity (PIE)?</label>
                                        <div class="col-sm-10">
                                            <input class="form-check-input" type="checkbox" id="gridCheck1">
                                        </div>
                                    </div>

                                    <div class="row mb-3">
                                        <label class="col-sm-2 col-form-label">Type of PIE</label>
                                        <div class="col-sm-10">
                                            <select class="form-control" id="riskLevel">
                                                <option value="Listed">Listed</option>
                                                <option value="FinancialInstitution">Financial Institution</option>
                                                <option value="LargeCharity">Large Charity</option>
                                                <option value="IPC">Large Institution of Public Character (“IPC”)</option>
                                            </select>
                                        </div>
                                    </div>

                                    <div class="row mb-3">
                                        <label class="col-sm-2 col-form-label">Is this a transnational entity (TNE)?</label>
                                        <div class="col-sm-10">
                                            <input class="form-check-input" type="checkbox" id="gridCheck1">
                                        </div>
                                    </div>

                                    <div class="row mb-3 align-items-center">
                                        <label class="col-sm-2 col-form-label">If this is a transnational audit (TNA)?</label>
                                        <div class="col-sm-10 d-flex align-items-center">
                                            <input class="form-check-input me-3" type="checkbox" id="gridCheck1">
                                        </div>
                                    </div>

                                </form>                         
                                <div class="table-responsive">
                                    <table class="table table-bordered table-striped">
                                        <thead class="table-light table-head-qc6">
                                            <tr>
                                                <th class="text-left pl-3 text-uppercase" style="width: 50%;">
                                                    Objectives and detailed tests
                                                </th>
                                                <th class="text-left text-uppercase">
                                                    Ref
                                                </th>
                                                <th class="text-left text-uppercase">
                                                    Sign/Date
                                                </th>
                                                <th class="text-left text-uppercase">
                                                    Ref/Comment
                                                </th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            <tr class="font-weight-bold" style="background-color: #f8f9fa;">
                                                <td colspan="4"><b>Objective – To ensure that the work for the client does not involve unacceptable risks</b></td>
                                            </tr>
                                            <tr class="text-zinc-700 dark:text-zinc-400">
                                                <td>
                                                    <div>
                                                        <p>
                                                            1. Decide whether we can rely on the management's integrity and whether association
                                                            with the client may damage the firm's reputation. Consider:
                                                        </p>
                                                        <ul>
                                                            <li>discussion with the party who introduced the client;</li>
                                                            <li>knowledge gained through work done by other departments within the firm;</li>
                                                            <li>media and any other reports;</li>
                                                            <li>client's relationship with any regulatory authority; and</li>
                                                            <li>client's attitude to fairness in financial reporting.</li>
                                                        </ul>
                                                    </div>
                                                </td>
                                                <td>
                                                    <input type="text"
                                                           class="form-control"
                                                           placeholder="Enter Ref" />
                                                </td>
                                                <td>
                                                    <input type="text"
                                                           class="form-control"
                                                           placeholder="Sign/Date" />
                                                </td>
                                                <td>
                                                    <input type="text"
                                                           class="form-control"
                                                           placeholder="Enter Comment" />
                                                </td>
                                            </tr>
                                            <tr class="text-zinc-700 dark:text-zinc-400">
                                                <td>
                                                    <div>
                                                        <p>
                                                            2. If we have doubts resulting from the considerations above, decide whether the
                                                            potential risks can be mitigated by introducing additional precautions, such as:
                                                        </p>
                                                        <ul>
                                                            <li>additional procedures, especially independent third-party confirmations; or</li>
                                                            <li>
                                                                additional review by an engagement quality reviewer (i.e. safeguard reviewer).
                                                            </li>
                                                        </ul>
                                                    </div>
                                                </td>
                                                <td>
                                                    <input type="text"
                                                           class="form-control"
                                                           placeholder="Enter Ref" />
                                                </td>
                                                <td>
                                                    <input type="text"
                                                           class="form-control"
                                                           placeholder="Sign/Date" />
                                                </td>
                                                <td>
                                                    <input type="text"
                                                           class="form-control"
                                                           placeholder="Enter Comment" />
                                                </td>
                                            </tr>
                                            <tr class="font-weight-bold" style="background-color: #f8f9fa;">
                                                <td colspan="4"><b>Objective – To ensure that the firm can comply with relevant ethical requirements</b></td>
                                            </tr>
                                            <tr class="text-zinc-700 dark:text-zinc-400">
                                                <td>
                                                    <div>
                                                        <p>
                                                            3. Consider whether the firm can comply with relevant ethical requirements, 
                                                            including the firm’s independence. Include in your consideration potential 
                                                            independence or conflicts of interest problems arising from relationships 
                                                            with other clients, firm members, or their families; providing non-assurance 
                                                            services; or unpaid fees.
                                                        </p>
                                                    </div>
                                                </td>
                                                <td>
                                                    <input type="text"
                                                           class="form-control"
                                                           placeholder="Enter Ref" />
                                                </td>
                                                <td>
                                                    <input type="text"
                                                           class="form-control"
                                                           placeholder="Sign/Date" />
                                                </td>
                                                <td>
                                                    <input type="text"
                                                           class="form-control"
                                                           placeholder="Enter Comment" />
                                                </td>
                                            </tr>
                                            <tr class="text-zinc-700 dark:text-zinc-400">
                                                <td>
                                                    <div>
                                                        <p>
                                                            4. Regarding the proposed relationship between the firm and the client or 
                                                            any associated companies, decide whether we are, and can be seen to be, 
                                                            independent of the client.  Consider:
                                                        </p>
                                                        <ul>
                                                            <li>Undue dependence</li>
                                                            <li>Proposed contingent fees</li>
                                                            <li>Preparation of accounting records</li>
                                                            <li>Receipt of hospitality, goods, or services</li>
                                                            <li>Voting on audit appointments</li>
                                                            <li>Director or senior employee joining client</li>
                                                            <li>Participation in affairs of client</li>
                                                            <li>Influences from the outside practice (including associated firms)</li>
                                                            <li>Litigation (actual or threatened)</li>
                                                            <li>Family or professional relationships</li>
                                                            <li>Prohibited services</li>
                                                            <li>Financial involvement, including trustee investments, 
                                                                mutual business interests, loans, beneficial interests- shares/trusts, overdue fees</li>
                                                            <li>Network form independence conflict checking procedures performed 
                                                                (i.e. conflict of interest to be considered by completing either “Audit and Review Engagements – 
                                                                Firm and Network Independence” or “Non-assurance Engagements – Firm and Network Independence,” 
                                                                which are part of this form.</li>
                                                        </ul>

                                                    </div>
                                                </td>
                                                <td>
                                                    <input type="text"
                                                           class="form-control"
                                                           placeholder="Enter Ref" />
                                                </td>
                                                <td>
                                                    <input type="text"
                                                           class="form-control"
                                                           placeholder="Sign/Date" />
                                                </td>
                                                <td>
                                                    <input type="text"
                                                           class="form-control"
                                                           placeholder="Enter Comment" />
                                                </td>
                                            </tr>
                                            <tr class="font-weight-bold" style="background-color: #f8f9fa;">
                                                <td colspan="4"><b>Objective - To ensure that the firm has the ability to perform the professional services properly</b></td>
                                            </tr>
                                            <tr class="text-zinc-700 dark:text-zinc-400">
                                                <td>
                                                    <div>
                                                        <p>
                                                            5. Decide whether we have the competence to carry out the professional services properly. 
                                                            Consider whether special skills are needed to deal with the particular features or specialised 
                                                            reporting requirements of the client.
                                                        </p>
                                                    </div>
                                                </td>
                                                <td>
                                                    <input type="text"
                                                           class="form-control"
                                                           placeholder="Enter Ref" />
                                                </td>
                                                <td>
                                                    <input type="text"
                                                           class="form-control"
                                                           placeholder="Sign/Date" />
                                                </td>
                                                <td>
                                                    <input type="text"
                                                           class="form-control"
                                                           placeholder="Enter Comment" />
                                                </td>
                                            </tr>
                                            <tr class="text-zinc-700 dark:text-zinc-400">
                                                <td>
                                                    <div>
                                                        <p>
                                                            6. Is there any reason to believe that management will not provide access to all 
                                                            information of which management is aware that is relevant to the preparation of 
                                                            the financial statements including access to information relevant to disclosures?
                                                        </p>
                                                    </div>
                                                </td>
                                                <td>
                                                    <input type="text"
                                                           class="form-control"
                                                           placeholder="Enter Ref" />
                                                </td>
                                                <td>
                                                    <input type="text"
                                                           class="form-control"
                                                           placeholder="Sign/Date" />
                                                </td>
                                                <td>
                                                    <input type="text"
                                                           class="form-control"
                                                           placeholder="Enter Comment" />
                                                </td>
                                            </tr>
                                            <tr class="text-zinc-700 dark:text-zinc-400">
                                                <td>
                                                    <div>
                                                        <p>
                                                            7. Confirm that the firm will have adequate resources to be able to do the work properly at the time the client needs it.
                                                            <br /> Note:  For example, to indicate if the engagement will be performed by outsourced staff.

                                                        </p>
                                                    </div>
                                                </td>
                                                <td>
                                                    <input type="text"
                                                           class="form-control"
                                                           placeholder="Enter Ref" />
                                                </td>
                                                <td>
                                                    <input type="text"
                                                           class="form-control"
                                                           placeholder="Sign/Date" />
                                                </td>
                                                <td>
                                                    <input type="text"
                                                           class="form-control"
                                                           placeholder="Enter Comment" />
                                                </td>
                                            </tr>
                                            <tr class="font-weight-bold" style="background-color: #f8f9fa;">
                                                <td colspan="4"><b>Objective - To ensure that our appointment is properly effected and that the scope of our work is acknowledged by the client</b></td>
                                            </tr>
                                            <tr class="text-zinc-700 dark:text-zinc-400">
                                                <td>
                                                    <div>
                                                        <p>
                                                            8. Send, and obtain a response to, a professional enquiry letter to the previous auditors/reporting accountants <b>(if any)</b>.
                                                        </p>
                                                    </div>
                                                </td>
                                                <td>
                                                    <input type="text"
                                                           class="form-control"
                                                           placeholder="Enter Ref" />
                                                </td>
                                                <td>
                                                    <input type="text"
                                                           class="form-control"
                                                           placeholder="Sign/Date" />
                                                </td>
                                                <td>
                                                    <input type="text"
                                                           class="form-control"
                                                           placeholder="Enter Comment" />
                                                </td>
                                            </tr>
                                            <tr class="text-zinc-700 dark:text-zinc-400">
                                                <td>
                                                    <div>
                                                        <p>
                                                            9. Obtain and review the previous auditor’s letter of resignation <b>(if applicable)</b> and statement of circumstances connected with their leaving office.
                                                        </p>
                                                    </div>
                                                </td>
                                                <td>
                                                    <input type="text"
                                                           class="form-control"
                                                           placeholder="Enter Ref" />
                                                </td>
                                                <td>
                                                    <input type="text"
                                                           class="form-control"
                                                           placeholder="Sign/Date" />
                                                </td>
                                                <td>
                                                    <input type="text"
                                                           class="form-control"
                                                           placeholder="Enter Comment" />
                                                </td>
                                            </tr>
                                            <tr class="text-zinc-700 dark:text-zinc-400">
                                                <td>
                                                    <div>
                                                        <p>
                                                            10.	Obtain a copy of the minutes appointing PKF as auditors.
                                                        </p>
                                                    </div>
                                                </td>
                                                <td>
                                                    <input type="text"
                                                           class="form-control"
                                                           placeholder="Enter Ref" />
                                                </td>
                                                <td>
                                                    <input type="text"
                                                           class="form-control"
                                                           placeholder="Sign/Date" />
                                                </td>
                                                <td>
                                                    <input type="text"
                                                           class="form-control"
                                                           placeholder="Enter Comment" />
                                                </td>
                                            </tr>
                                            <tr class="text-zinc-700 dark:text-zinc-400">
                                                <td>
                                                    <div>
                                                        <p>
                                                            11.	Send an engagement letter and obtain the client’s agreement to its terms before starting work.

                                                        </p>
                                                    </div>
                                                </td>
                                                <td>
                                                    <input type="text"
                                                           class="form-control"
                                                           placeholder="Enter Ref" />
                                                </td>
                                                <td>
                                                    <input type="text"
                                                           class="form-control"
                                                           placeholder="Sign/Date" />
                                                </td>
                                                <td>
                                                    <input type="text"
                                                           class="form-control"
                                                           placeholder="Enter Comment" />
                                                </td>
                                            </tr>
                                            <tr class="text-zinc-700 dark:text-zinc-400">
                                                <td>
                                                    <div>
                                                        <p>
                                                            12.	Carry out other tests necessary to meet this objective and document such additional considerations.
                                                        </p>
                                                    </div>
                                                </td>
                                                <td>
                                                    <input type="text"
                                                           class="form-control"
                                                           placeholder="Enter Ref" />
                                                </td>
                                                <td>
                                                    <input type="text"
                                                           class="form-control"
                                                           placeholder="Sign/Date" />
                                                </td>
                                                <td>
                                                    <input type="text"
                                                           class="form-control"
                                                           placeholder="Enter Comment" />
                                                </td>
                                            </tr>
                                            <tr class="font-weight-bold" style="background-color: #f8f9fa;">
                                                <td colspan="4"><b>Objective – To ensure that the entity has been properly constituted in compliance with relevant legislation.</b></td>
                                            </tr>
                                            <tr class="text-zinc-700 dark:text-zinc-400">
                                                <td>
                                                    <div>
                                                        <p>
                                                            13.	Obtain and file documents of constitution and certificate of incorporation <b>(where applicable)</b>.
                                                        </p>
                                                    </div>
                                                </td>
                                                <td>
                                                    <input type="text"
                                                           class="form-control"
                                                           placeholder="Enter Ref" />
                                                </td>
                                                <td>
                                                    <input type="text"
                                                           class="form-control"
                                                           placeholder="Sign/Date" />
                                                </td>
                                                <td>
                                                    <input type="text"
                                                           class="form-control"
                                                           placeholder="Enter Comment" />
                                                </td>
                                            </tr>
                                            <tr class="text-zinc-700 dark:text-zinc-400">
                                                <td>
                                                    <div>
                                                        <p>
                                                            14.	Where possible, verify that appropriate documents have been filed with the relevant authorities and that these support the information provided by the entity’s records.
                                                        </p>
                                                    </div>
                                                </td>
                                                <td>
                                                    <input type="text"
                                                           class="form-control"
                                                           placeholder="Enter Ref" />
                                                </td>
                                                <td>
                                                    <input type="text"
                                                           class="form-control"
                                                           placeholder="Sign/Date" />
                                                </td>
                                                <td>
                                                    <input type="text"
                                                           class="form-control"
                                                           placeholder="Enter Comment" />
                                                </td>
                                            </tr>
                                            <tr class="text-zinc-700 dark:text-zinc-400">
                                                <td>
                                                    <div>
                                                        <p>
                                                            15.	Carry out other tests if necessary to achieve this objective.
                                                        </p>
                                                    </div>
                                                </td>
                                                <td>
                                                    <input type="text"
                                                           class="form-control"
                                                           placeholder="Enter Ref" />
                                                </td>
                                                <td>
                                                    <input type="text"
                                                           class="form-control"
                                                           placeholder="Sign/Date" />
                                                </td>
                                                <td>
                                                    <input type="text"
                                                           class="form-control"
                                                           placeholder="Enter Comment" />
                                                </td>
                                            </tr>
                                            <tr class="text-zinc-700 dark:text-zinc-400">
                                                <td>
                                                    <div>
                                                        <p>
                                                        16. Carry out procedures for establishing/verifying the identity of new clients for possible instances of money laundering if there are indicators or suspicion of such activities based on the evaluation of integrity of the new client set out above.
                                                        <ol class="list-decimal pl-4">
                                                            <li>Perform a search of the company’s name, all directors and ultimate beneficial owners owning more than 25% equity interest in the ultimate holding company using LexisNexis. This screening covers not only identifying any PEPs but also terrorist names, terrorist organisations and names sanctioned by United States / United Nations. A copy of the screening should be attached to QC6(3).</li>
                                                            <br>
                                                            <li>Carry out a google check on the company’s name, names of the directors and ultimate BOs owning more than 25% equity interest in the ultimate holding company. A copy of the google check should be attached to QC6(3).</li>
                                                            <br>
                                                            <li>For audit clients whereby the companies are incorporated by our related entities, PKF-CAP Corporate Services Pte Ltd (“CS”) or PKF-Khoo Management Services Pte Ltd (“KMS”), then carry out a review of the screening and google checking that have been carried out by CS or KMS. If the result is satisfactory, then document the review that you have performed. No further screening or checking is required unless work performed is considered not adequate for our purposes. This placing of reliance is acceptable so long as the screening carried out by CS or KMS is current within 12 months from our client/engagement evaluation date.</li>
                                                        </ol>
                                                        <i>
