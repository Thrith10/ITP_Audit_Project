@model PKFAuditManagement.ViewModels.QuizViewModel

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Edit Quiz</title>
    <link rel="stylesheet" href="~/css/edit-quiz.css">
    <script src="https://cdnjs.cloudflare.com/ajax/libs/xlsx/0.18.5/xlsx.full.min.js"></script>
    <script src="~/js/edit-quiz.js" defer></script>

</head>
<body>


    <main>
        <section class="section dashboard">
            <div class="row">
                <div class="col-12">
                    <div class="row">
                        <div class="col-xxl-12 col-md-12">
                            <div class="card info-card customers-card">
                                <div class="card-body">
                                    <div class="form-container">
                                        <!-- Success message display -->
                                        @if (TempData["SuccessMessage"] != null)
                                        {
                                            <div class="alert alert-success">
                                                @TempData["SuccessMessage"]
                                            </div>
                                        }

                                        <!-- Form to edit quiz details -->
                                        <form asp-action="Edit" method="post">
                                            @* Hidden field for the QuizID *@
                                            <input type="hidden" asp-for="QuizID" />

                                            <!-- Quiz title input -->
                                            <div class="form-group">
                                                <label asp-for="Title">Quiz Title</label>
                                                <input asp-for="Title" class="form-control" required />
                                            </div>

                                            <!-- Quiz description input -->
                                            <div class="form-group">
                                                <label asp-for="Description">Description</label>
                                                <textarea asp-for="Description" class="form-control" required></textarea>
                                            </div>

                                            <!-- Quiz start date and time -->
                                            <div class="form-group">
                                                <label asp-for="QuizStart">Quiz Start</label>
                                                <input asp-for="QuizStart" class="form-control" type="datetime-local" required />
                                            </div>

                                            <!-- Participant selection options -->
                                            <div class="form-group">
                                                <label>Participants (Selection is limited to registered users only)</label>
                                                <br />

                                                <!-- Buttons to select participants or upload via Excel -->
                                                <button type="button" id="select-participants-btn" class="btn btn-secondary btn-sm">
                                                    Select Participants
                                                </button>
                                                <span class="separator">OR</span>
                                                <button type="button" id="upload-participants-btn" class="btn btn-secondary btn-sm">
                                                    Upload via Excel
                                                </button>

                                                <!-- Display selected participant count -->
                                                <span id="participants-count" class="clickable" style="margin-left: 10px; color: blue; cursor: pointer;">
                                                    0 participants selected
                                                </span>

                                                <!-- Hidden input for Excel upload -->
                                                <input type="file" id="ExcelFile" name="ExcelFile" accept=".xlsx" style="display: none;" />
                                            </div>

                                            <!-- Hidden input for selected participants -->
                                            <input type="hidden" id="SelectedParticipants" asp-for="SelectedParticipants" />

                                            <!-- Quiz questions loop -->
                                            <div id="quiz-container">
                                                @for (int i = 0; i < Model.Questions.Count; i++)
                                                {
                                                    var question = Model.Questions[i];
                                                    <div class="card mb-3" data-index="@i">
                                                        <div class="card-body">
                                                            <div class="d-flex justify-content-between align-items-center">
                                                                <h5 class="card-title">Question @(i + 1):</h5>

                                                                @if (i > 0)
                                                                {
                                                                    <button type="button" class="btn btn-danger btn-sm remove-question">
                                                                        <i class="bi bi-trash"></i> Remove Question
                                                                    </button>
                                                                }
                                                            </div>
                                                            <div class="form-group">
                                                                <input type="text" class="form-control" name="Questions[@i].Description" value="@question.Description" required />
                                                            </div>
                                                            <div class="form-group">
                                                                <label>Options:</label>
                                                                <div class="options-container">
                                                                    @for (int j = 0; j < question.Options.Count; j++)
                                                                    {
                                                                        var option = question.Options[j];
                                                                        <div class="input-group mb-2 option-group">
                                                                            <input type="text" class="form-control" name="Questions[@i].Options[@j].OptionText" value="@option.OptionText" data-option-index="@j" required />
                                                                            <button type="button" class="btn btn-danger btn-sm remove-option">
                                                                                <i class="bi bi-trash"></i>
                                                                            </button>
                                                                        </div>
                                                                    }
                                                                </div>
                                                                <button type="button" class="btn btn-secondary btn-sm add-option btn-add" data-question-index="@i">
                                                                    <i class="bi bi-plus-lg"></i> Add Option
                                                                </button>
                                                            </div>
                                                            <div class="form-group">
                                                                <label>Select the correct answer:</label>
                                                                <select class="form-control" name="Questions[@i].CorrectOptionText" required>
                                                                    @for (int j = 0; j < question.Options.Count; j++)
                                                                    {
                                                                        var option = question.Options[j];
                                                                        <option value="@option.OptionText">@option.OptionText</option>
                                                                    }
                                                                </select>
                                                            </div>
                                                        </div>
                                                    </div>
                                                }

                                            </div>

                                            <!-- Add question and submit buttons -->
                                            <div class="btn-container">
                                                <button type="button" class="btn btn-secondary btn-sm add-question btn-add" id="add-question">
                                                    <i class="bi bi-plus-lg"></i> Add Question
                                                </button>
                                                <button type="submit" id="submit-button" class="btn btn-primary btn-sm">Save</button>
                                            </div>
                                        </form>

                                        <!-- Participants selection modal -->
                                        <div id="participants-modal" class="modal">
                                            <div class="modal-content">
                                                <span class="close-modal">&times;</span>
                                                <h5>Select Participants</h5>
                                                <div class="button-container">
                                                    <button id="select-all" class="select-all-btn btn btn-primary">Select All</button>
                                                </div>
                                                <div class="participants-list">
                                                    <!-- Dynamically populated list -->
                                                </div>
                                                <div class="pagination">
                                                    <button class="prev-page btn btn-secondary">Prev</button>
                                                    <span class="current-page">1</span>
                                                    <button class="next-page btn btn-secondary">Next</button>
                                                </div>
                                                <div class="button-container">
                                                    <button type="button" id="confirm-participants-btn" class="btn btn-primary">Confirm</button>
                                                </div>
                                            </div>
                                        </div>

                                        <!-- Selected participants modal -->
                                        <div id="selectedParticipantsModal" class="modal" style="display:none;">
                                            <div class="modal-content">
                                                <span id="closeSelectedParticipantsModal" class="close">&times;</span>
                                                <h4>Selected Participants</h4>
                                                <div class="scrollable-participants-list" style="max-height: 300px; overflow-y: auto; border: 1px solid #ccc; padding: 10px;">
                                                    <ul id="selectedParticipantsList"></ul>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </section>
    </mainstyle>

</body>
</html>
