@model PKFAuditManagement.ViewModels.QuizViewModel

<head>
    <style>
        /* Tab styles */
        .nav-tabs {
            display: flex;
            justify-content: space-around;
            margin-bottom: 20px;
        }

            .nav-tabs button {
                background-color: #f8f9fa;
                border: 1px solid #dee2e6;
                padding: 10px 20px;
                cursor: pointer;
                transition: background-color 0.3s ease;
                border-radius: 4px;
                flex: 1;
                text-align: center;
            }

                .nav-tabs button.active {
                    background-color: #007bff;
                    color: white;
                }

                .nav-tabs button:hover {
                    background-color: #e2e6ea;
                }

        .tab-content {
            display: none;
        }

            .tab-content.active {
                display: block;
            }
    </style>
</head>

<main id="main" class="main">
    <section class="section dashboard">
        <div class="row">
            <div class="col-12">
                <div class="card info-card">
                    <div class="card-body">
                        <h5 class="card-title">Quiz Creation</h5>

                        <!-- Tab Navigation -->
                        <div class="nav-tabs">
                            <button id="manual-tab" class="tab-link active">Manual Quiz Creation</button>
                            <button id="excel-tab" class="tab-link">Excel Quiz Creation</button>
                        </div>

                        <!-- Manual Quiz Creation Tab Content -->
                        <div id="manual-content" class="tab-content active">
                            @Html.Partial("~/Views/General/Quiz/ManualQuizCreation.cshtml")
                        </div>

                        <!-- Excel Quiz Creation Tab Content -->
                        <div id="excel-content" class="tab-content">
                            @Html.Partial("~/Views/General/Quiz/ExcelQuizCreation.cshtml")
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <script>
        document.addEventListener('DOMContentLoaded', function () {
            // Tab switching logic
            var manualTab = document.getElementById('manual-tab');
            var excelTab = document.getElementById('excel-tab');
            var manualContent = document.getElementById('manual-content');
            var excelContent = document.getElementById('excel-content');

            // Ensure sidebar is closed on page load
            var sidebar = document.querySelector('.sidebar'); // Adjust this selector to your sidebar
            var toggleSidebarBtn = document.querySelector('.toggle-sidebar-btn'); // The hamburger menu button
            toggleSidebarBtn.click();
     

            // Switch to Manual Quiz Creation tab
            manualTab.addEventListener('click', function () {
                manualTab.classList.add('active');
                excelTab.classList.remove('active');
                manualContent.classList.add('active');
                excelContent.classList.remove('active');
            });

            // Switch to Excel Quiz Creation tab
            excelTab.addEventListener('click', function () {
                excelTab.classList.add('active');
                manualTab.classList.remove('active');
                excelContent.classList.add('active');
                manualContent.classList.remove('active');
            });
        });
    </script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/xlsx/0.18.5/xlsx.full.min.js"></script>
    <script src="~/js/manual-quiz-creation.js"></script>
</main>
