@model PKFAuditManagement.ViewModels.QuizViewModel

<head>
    <link rel="stylesheet" href="~/css/create-quiz-main.css">
    <link rel="stylesheet" href="~/css/manual-quiz-creation.css">
    <link rel="stylesheet" href="~/css/quiz-auto-filled.css">
    <script src="~/js/create-quiz-main.js" defer></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/xlsx/0.18.5/xlsx.full.min.js" defer></script>
    <script src="~/js/manual-quiz-creation.js" defer></script>
    <script src="~/js/excel-quiz-creation.js" defer></script>
    <script src="~/js/quiz-auto-filled.js" defer></script>
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <link href="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/css/select2.min.css" defer rel="stylesheet" />
    <script src="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/js/select2.min.js" defer ></script>
    <style>
        label {
            font-weight: bold;
        }
    </style>
</head>

<main id="main" class="main">
    <section class="section dashboard">
        <div class="row">
            <div class="col-12">
                <div class="card info-card">
                    <div class="card-body">
                        <h5 class="card-title">Quiz Creation</h5>

                        <!-- Tab Navigation -->
                        <div class="nav-tabs">
                            <button id="manual-tab" class="tab-link active">Manual Quiz Creation</button>
                            <button id="excel-tab" class="tab-link">Excel Quiz Creation</button>
                        </div>

                        <!-- Manual Quiz Creation Tab Content -->
                        <div id="manual-content" class="tab-content active">
                            @Html.Partial("~/Views/General/Quiz/ManualQuizCreation.cshtml")
                        </div>

                        <!-- Excel Quiz Creation Tab Content -->
                        <div id="excel-content" class="tab-content">
                            @Html.Partial("~/Views/General/Quiz/ExcelQuizCreation.cshtml")
                        </div>
                    </div>
                    <!-- End Customers Card -->
                </div>
            </div>
        </div>
    </section>
</main>
