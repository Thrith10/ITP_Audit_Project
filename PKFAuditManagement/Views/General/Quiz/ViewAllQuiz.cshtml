@model PKFAuditManagement.ViewModels.QuizListViewModel

<!DOCTYPE html>
<html lang="en">

<head>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdnjs.cloudflare.com/ajax/libs/bootstrap-icons/1.8.1/font/bootstrap-icons.min.css" rel="stylesheet">
    <style>
        .form-container {
            padding: 20px;
        }

        .btn-primary,
        .btn-secondary,
        .btn-danger {
            padding: 0.5rem 1rem;
        }

        .btn-add {
            margin-top: 0.5rem;
        }

        .card {
            margin-bottom: 1rem;
            padding: 1rem;
        }

        .input-group {
            margin-bottom: 1rem;
        }

        .form-group {
            margin-bottom: 1.5rem;
        }

        .card-title {
            margin-bottom: 1rem;
        }

        .btn-container {
            display: flex;
            justify-content: flex-end;
            gap: 10px;
        }

            .btn-container .btn {
                flex: 0 0 auto;
            }

        .no-quiz-container {
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            height: 50vh;
        }

        .no-quiz-message {
            margin-bottom: 1rem;
        }

        .header-container {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 1rem;
        }

        .card-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 1rem;
            background-color: #ffffff;
            border-bottom: none;
        }

            .card-header h5 {
                margin: 0;
            }

        .card-body {
            padding-top: 0;
        }
    </style>
</head>

<body>
    <main id="main" class="main">

        <section class="section dashboard">
            <div class="row">
                <!-- Left side columns -->
                <div class="col-12">
                    <div class="row">
                        <div class="col-xxl-12 col-md-12">
                            <div class="card info-card customers-card">
                                <div class="card-header">
                                    <h5 class="card-title">All Quizzes</h5>
                                    <a href="@Url.Action("Create", "Quizzes")" class="btn btn-primary btn-sm">
                                        Create Quiz
                                    </a>
                                </div>
                                <div class="card-body">
                                    <div class="form-container">
                                        @if (TempData["SuccessMessage"] != null)
                                        {
                                            <div class="alert alert-success">
                                                @TempData["SuccessMessage"]
                                            </div>
                                        }

                                        @if (Model.Quizzes.Any())
                                        {
                                            @foreach (var quiz in Model.Quizzes)
                                            {
                                                <div class="card mb-3">
                                                    <div class="card-body d-flex justify-content-between align-items-center">
                                                        <div>
                                                            <h5 class="card-title">@quiz.Title</h5>
                                                            <p class="card-text">@quiz.Description</p>
                                                        </div>
                                                        <div class="btn-container">
                                                            <a href="@Url.Action("Details", "Quizzes", new { id = quiz.QuizID })" class="btn btn-primary btn-sm">
                                                                View Details
                                                            </a>
                                                            <form asp-action="Delete" method="post" onsubmit="return confirm('Are you sure you want to delete this quiz?');">
                                                                <input type="hidden" name="id" value="@quiz.QuizID" />
                                                                <button type="submit" class="btn btn-danger btn-sm">
                                                                    <i class="bi bi-trash"></i> Delete Quiz
                                                                </button>
                                                            </form>
                                                        </div>
                                                    </div>
                                                </div>
                                            }
                                        }
                                        else
                                        {
                                            <div class="no-quiz-container">
                                                <div class="no-quiz-message">
                                                    <h5>No Quiz Available</h5>
                                                </div>
                                                <a href="@Url.Action("Create", "Quizzes")" class="btn btn-primary btn-sm">
                                                    Create Quiz
                                                </a>
                                            </div>
                                        }
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div><!-- End Left side columns -->
            </div>
        </section>
    </main><!-- End #main -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/js/bootstrap.bundle.min.js"></script>
</body>

</html>
