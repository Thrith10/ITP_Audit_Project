@model PKFAuditManagement.ViewModels.QuizListViewModel

<!DOCTYPE html>
<html lang="en">

<head>
    <link href="https://cdnjs.cloudflare.com/ajax/libs/bootstrap/5.1.3/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdnjs.cloudflare.com/ajax/libs/bootstrap-icons/1.8.1/font/bootstrap-icons.min.css" rel="stylesheet">
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/qrcodejs/1.0.0/qrcode.min.js"></script> <!-- QR Code Library -->
    <style>
        .form-container {
            padding: 20px;
        }

        .table-container {
            margin-top: 1rem;
        }

        .search-input {
            width: 100%;
            max-width: 300px;
            margin-bottom: 1rem;
        }

        .table-section {
            margin-bottom: 2rem;
        }

        h5.section-title {
            margin-bottom: 1rem;
        }

        .no-quiz-container {
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            height: 50vh;
            color: #6c757d;
            text-align: center;
        }

        .no-quiz-container .icon {
            font-size: 3rem;
            margin-bottom: 1rem;
            color: #adb5bd;
        }

        .no-quiz-container h5 {
            margin-bottom: 1rem;
            font-size: 1.5rem;
            color: #495057;
        }

        .no-quiz-container .btn {
            margin-top: 1rem;
        }

        .card-title {
            padding: 0px 0 0px 0;
            font-size: 20px;
            font-weight: 500;
            color: #012970;
            font-family: "Poppins", sans-serif;
            margin-top: 10px;
        }

        #create-btn {
            margin-top: 10px;
            padding-top: 6px;
        }

        /* Modal QR Code Size */
        #qrCode {
            margin: 0 auto;
            width: 600px;
            height: 600px;
        }

        /* Custom style for Show QR Code button */
        .show-qr-btn {
            background: linear-gradient(45deg, #00802b, #00802b);
            border: none;
            color: white;
            padding: 0.4rem 0.75rem;
            font-size: 0.875rem;
            border-radius: 4px;
            transition: background 0.3s ease;
        }

        .show-qr-btn:hover {
            background: linear-gradient(45deg, #388E3C, #66BB6A);
        }

        /* Fixed column widths and word wrapping */
        table {
            table-layout: fixed;
            width: 100%;
        }

        th,
        td {
            word-wrap: break-word;
            white-space: normal;
            vertical-align: middle;
            cursor: pointer; /* Indicates that the column headers are clickable */
        }

        th.date-time,
        td.date-time {
            width: 10%;
            white-space: nowrap;
        }

        th {
            width: 30%;
        }

        th.actions,
        td.actions {
            width: 25%;
        }

        /* Styling for tabs */
        .nav-tabs {
            margin-bottom: 1rem;
        }

        .tab-content {
            margin-top: 1rem;
        }

        .nav-link.active {
            background-color: #f8f9fa !important;
            border-color: #dee2e6 #dee2e6 #f8f9fa !important;
        }

        .tab-content .table {
            margin-top: 1rem;
        }
    </style>

</head>

<body>
    <main id="main" class="main">
        <section class="section dashboard">
            <div class="row">
                <div class="col-12">
                    <div class="row">
                        <div class="col-xxl-12 col-md-12">
                            <div class="card info-card customers-card">
                                <div class="card-header d-flex justify-content-between">
                                    <h class="card-title">All Quizzes</h>
                                    <a href="@Url.Action("Create", "Quizzes")" class="btn btn-primary btn-sm" id="create-btn">
                                        Create Quiz
                                    </a>
                                </div>
                                <div class="card-body">
                                    <div class="form-container">
                                        @if (TempData["SuccessMessage"] != null)
                                        {
                                            <div class="alert alert-success">
                                                @TempData["SuccessMessage"]
                                            </div>
                                        }

                                        @if (TempData["ErrorMessage"] != null)
                                        {
                                            <div class="alert alert-danger">
                                                <span>@TempData["ErrorMessage"]</span>
                                                <button type="button" class="btn btn-danger" data-bs-toggle="modal" data-bs-target="#deleteAllModal" data-quiz-id="@TempData["DeleteQuizID"]">Yes, Delete All</button>

                                            </div>
                                        }

                                        <!-- Tabs for Upcoming and Past Quizzes -->
                                        <ul class="nav nav-tabs" id="quizTabs" role="tablist">
                                            <li class="nav-item" role="presentation">
                                                <button class="nav-link active" id="upcoming-quizzes-tab" data-bs-toggle="tab" data-bs-target="#upcoming-quizzes" type="button" role="tab" aria-controls="upcoming-quizzes" aria-selected="true">Upcoming Quizzes</button>
                                            </li>
                                            <li class="nav-item" role="presentation">
                                                <button class="nav-link" id="past-quizzes-tab" data-bs-toggle="tab" data-bs-target="#past-quizzes" type="button" role="tab" aria-controls="past-quizzes" aria-selected="false">Past Quizzes</button>
                                            </li>
                                        </ul>

                                        <div class="tab-content" id="quizTabContent">
                                            <!-- Upcoming Quizzes -->
                                            <div class="tab-pane fade show active" id="upcoming-quizzes" role="tabpanel" aria-labelledby="upcoming-quizzes-tab">
                                                <h5 class="section-title">Upcoming Quizzes</h5>
                                                <input type="text" id="searchUpcomingInput" class="form-control search-input" placeholder="Search upcoming quizzes...">
                                                @if (Model.Quizzes.Where(q => q.QuizEnd > DateTime.Now).OrderByDescending(q => q.QuizStart).Any())
                                                {
                                                    <div class="table-container">
                                                        <table class="table table-bordered table-striped" id="upcomingQuizTable">
                                                            <thead class="table-dark">
                                                                <tr>
                                                                    <th>Quiz Title</th>
                                                                    <th>Description</th>
                                                                    <th class="date-time">Quiz Start</th>
                                                                    <th class="date-time">Quiz End</th>
                                                                    <th class="actions">Actions</th>
                                                                </tr>
                                                            </thead>
                                                            <tbody>
                                                                @foreach (var quiz in Model.Quizzes.Where(q => q.QuizEnd > DateTime.Now).OrderByDescending(q => q.QuizStart))
                                                                {
                                                                    <tr>
                                                                        <td>@quiz.Title</td>
                                                                        <td>@quiz.Description</td>
                                                                        <td class="date-time">@quiz.QuizStart.ToString("yyyy-MM-dd HH:mm")</td>
                                                                        <td class="date-time">@quiz.QuizEnd.ToString("yyyy-MM-dd HH:mm")</td>
                                                                        <td class="actions">
                                                                            <a href="@Url.Action("Details", "Quizzes", new { id = quiz.QuizID })" class="btn btn-primary btn-sm">View Details</a>
                                                                            <button type="button" class="btn show-qr-btn" data-quiz-id="@quiz.QuizID" data-bs-toggle="modal" data-bs-target="#qrModal">Show QR Code</button>

                                                                            <!-- Button that triggers the Delete Confirmation Modal -->
                                                                            <button type="button" class="btn btn-danger btn-sm" data-bs-quiz-id="@quiz.QuizID" data-bs-toggle="modal" data-bs-target="#deleteModal">
                                                                                <i class="bi bi-trash"></i> Delete
                                                                            </button>
                                                                        </td>
                                                                    </tr>
                                                                }
                                                            </tbody>

                                                        </table>
                                                    </div>
                                                }
                                                else
                                                {
                                                    <div class="no-quiz-container">
                                                        <i class="bi bi-calendar-x icon"></i>
                                                        <h5>No Upcoming Quizzes Available</h5>
                                                        <a href="@Url.Action("Create", "Quizzes")" class="btn btn-primary btn-sm">Create Quiz</a>
                                                    </div>
                                                }
                                            </div>

                                            <!-- Past Quizzes -->
                                            <div class="tab-pane fade" id="past-quizzes" role="tabpanel" aria-labelledby="past-quizzes-tab">
                                                <h5 class="section-title">Past Quizzes</h5>
                                                <input type="text" id="searchPastInput" class="form-control search-input" placeholder="Search past quizzes...">
                                                @if (Model.Quizzes.Where(q => q.QuizEnd < DateTime.Now).OrderByDescending(q => q.QuizEnd).Any())
                                                {
                                                    <div class="table-container">
                                                        <table class="table table-bordered table-striped" id="pastQuizTable">
                                                            <thead class="table-dark">
                                                                <tr>
                                                                    <th>Quiz Title</th>
                                                                    <th>Description</th>
                                                                    <th>Quiz Start</th>
                                                                    <th>Quiz End</th>
                                                                    <th>Actions</th>
                                                                </tr>
                                                            </thead>
                                                            <tbody>
                                                                @foreach (var quiz in Model.Quizzes.Where(q => q.QuizEnd > DateTime.Now).OrderByDescending(q => q.QuizStart))
                                                                {
                                                                    <tr>
                                                                        <td>@quiz.Title</td>
                                                                        <td>@quiz.Description</td>
                                                                        <td class="date-time">@quiz.QuizStart.ToString("yyyy-MM-dd HH:mm")</td>
                                                                        <td class="date-time">@quiz.QuizEnd.ToString("yyyy-MM-dd HH:mm")</td>
                                                                        <td class="actions">
                                                                            <a href="@Url.Action("Details", "Quizzes", new { id = quiz.QuizID })" class="btn btn-primary btn-sm">View Details</a>
                                                                            <button type="button" class="btn show-qr-btn" data-quiz-id="@quiz.QuizID" data-bs-toggle="modal" data-bs-target="#qrModal">Show QR Code</button>

                                                                            <!-- Button that triggers the Delete Confirmation Modal -->
                                                                            <button type="button" class="btn btn-danger btn-sm" data-bs-quiz-id="@quiz.QuizID" data-bs-toggle="modal" data-bs-target="#deleteModal">
                                                                                <i class="bi bi-trash"></i> Delete
                                                                            </button>
                                                                        </td>
                                                                    </tr>
                                                                }
                                                            </tbody>

                                                        </table>
                                                    </div>
                                                }
                                                else
                                                {
                                                    <div class="no-quiz-container">
                                                        <i class="bi bi-calendar-x icon"></i>
                                                        <h5>No Past Quizzes Available</h5>
                                                    </div>
                                                }
                                            </div>
                                        </div>

                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div><!-- End Left side columns -->
            </div>
        </section>
    </main>
    <!-- Delete Confirmation Modal -->
    <div class="modal fade" id="deleteModal" tabindex="-1" aria-labelledby="deleteModalLabel" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title" id="deleteModalLabel">Confirm Quiz Deletion</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <p>Are you sure you want to delete this quiz? This action cannot be undone.</p>
                </div>
                <div class="modal-footer">
                    <!-- Form for deleting the quiz -->
                    <form id="deleteForm" method="post" data-quiz-id="">
                        @Html.AntiForgeryToken() <!-- Anti-forgery token for security -->
                        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                        <button type="submit" class="btn btn-danger">Yes, Delete</button>
                    </form>
                </div>
            </div>
        </div>
    </div>


    <!-- Delete All Confirmation Modal -->
    <div class="modal fade" id="deleteAllModal" tabindex="-1" aria-labelledby="deleteAllModalLabel" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title" id="deleteAllModalLabel">Confirm Delete Quiz and All Data</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <p>Are you sure you want to delete this quiz and all related participants, attempts, and responses?</p>
                </div>
                <div class="modal-footer">
                    <!-- Form for deleting the quiz and all related data -->
                    <form id="deleteAllForm" asp-action="ConfirmDeleteWithAssociation" method="post">
                        @Html.AntiForgeryToken() <!-- Anti-forgery token for security -->
                        <input type="hidden" name="id" id="quizToDeleteId" /> <!-- Hidden field for quiz ID -->
                        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                        <button type="submit" class="btn btn-danger">Yes, Delete All</button>
                    </form>
                </div>
            </div>
        </div>
    </div>




    <!-- QR Code Modal -->
    <div class="modal fade" id="qrModal" tabindex="-1" aria-labelledby="qrModalLabel" aria-hidden="true">
        <div class="modal-dialog modal-lg modal-dialog-centered">
            <!-- Set modal to large size -->
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title" id="qrModalLabel">Quiz QR Code</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body text-center">
                    <div id="qrCode"></div> <!-- QR code container -->
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
                </div>
            </div>
        </div>
    </div>

    <script>
        // Filter Upcoming Quizzes
        $(document).ready(function () {
            $('#searchUpcomingInput').on('keyup', function () {
                var value = $(this).val().toLowerCase();
                $('#upcomingQuizTable tbody tr').filter(function () {
                    $(this).toggle($(this).text().toLowerCase().indexOf(value) > -1)
                });
            });

            // Filter Past Quizzes
            $('#searchPastInput').on('keyup', function () {
                var value = $(this).val().toLowerCase();
                $('#pastQuizTable tbody tr').filter(function () {
                    $(this).toggle($(this).text().toLowerCase().indexOf(value) > -1)
                });
            });

            // Show QR Code in Modal
            $('.show-qr-btn').on('click', function () {
                var quizId = $(this).data('quiz-id');
                $('#qrCode').empty(); // Clear any previous QR code
                new QRCode(document.getElementById("qrCode"), {
                    text: quizId,  // Quiz ID GUID as text
                    width: 600,   // Increased size (2x)
                    height: 600   // Increased size (2x)
                });
            });
            // When the delete button is clicked, pass the quiz ID to the delete form in the modal
            $('button[data-bs-target="#deleteModal"]').on('click', function () {
                var quizId = $(this).data('bs-quiz-id');

                // Set the action attribute of the form to the delete URL with the correct quiz ID
                var deleteUrl = '@Url.Action("Delete", "Quizzes", new { id = "__quizId__" })';
                deleteUrl = deleteUrl.replace("__quizId__", quizId);

                // Update the form action and quiz ID
                $('#deleteForm').attr('action', deleteUrl);
            });


            $('.btn-danger[data-bs-target="#deleteAllModal"]').on('click', function () {
                var quizId = $(this).data('quiz-id');
                $('#quizToDeleteId').val(quizId); // Pass quiz ID to hidden input field
            });

            // Sorting logic for the tables
            function sortTable(table, colIndex, ascending) {
                var rows = $(table).find('tbody > tr').get();
                rows.sort(function (a, b) {
                    var cellA = $(a).children('td').eq(colIndex).text().toLowerCase();
                    var cellB = $(b).children('td').eq(colIndex).text().toLowerCase();

                    if ($.isNumeric(cellA) && $.isNumeric(cellB)) {
                        return ascending ? cellA - cellB : cellB - cellA;
                    } else {
                        return ascending ? cellA.localeCompare(cellB) : cellB.localeCompare(cellA);
                    }
                });
                $.each(rows, function (index, row) {
                    $(table).children('tbody').append(row);
                });
            }

            // Add click event to headers for sorting
            $('th').on('click', function () {
                var table = $(this).closest('table');
                var colIndex = $(this).index();
                var ascending = $(this).hasClass('ascending');
                $(table).find('th').removeClass('ascending descending');
                $(this).toggleClass('ascending', !ascending);
                $(this).toggleClass('descending', ascending);
                sortTable(table, colIndex, !ascending);
            });
        });
    </script>
</body>

</html>
