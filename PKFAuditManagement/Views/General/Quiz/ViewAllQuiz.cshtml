@model PKFAuditManagement.ViewModels.QuizListViewModel

<!DOCTYPE html>
<html lang="en">

<head>
    <link href="https://cdnjs.cloudflare.com/ajax/libs/bootstrap/5.1.3/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdnjs.cloudflare.com/ajax/libs/bootstrap-icons/1.8.1/font/bootstrap-icons.min.css" rel="stylesheet">
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/qrcodejs/1.0.0/qrcode.min.js"></script> <!-- QR Code Library -->
    <style>
        <style >
        .form-container {
            padding: 20px;
        }

        .table-container {
            margin-top: 1rem;
        }

        .search-input {
            width: 100%;
            max-width: 300px;
            margin-bottom: 1rem;
        }

        .table-section {
            margin-bottom: 2rem;
        }

        h5.section-title {
            margin-bottom: 1rem;
        }

        .no-quiz-container {
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            height: 50vh;
            color: #6c757d;
            text-align: center;
        }

            .no-quiz-container .icon {
                font-size: 3rem;
                margin-bottom: 1rem;
                color: #adb5bd;
            }

            .no-quiz-container h5 {
                margin-bottom: 1rem;
                font-size: 1.5rem;
                color: #495057;
            }

            .no-quiz-container .btn {
                margin-top: 1rem;
            }

        .card-title {
            padding: 0px 0 0px 0;
            font-size: 20px;
            font-weight: 500;
            color: #012970;
            font-family: "Poppins", sans-serif;
            margin-top: 10px;
        }

        #create-btn {
            margin-top: 10px;
            padding-top: 6px;
        }

        /* Modal QR Code Size */
        #qrCode {
            margin: 0 auto;
            width: 600px; /* QR Code size */
            height: 600px; /* QR Code size */
        }

        /* Custom style for Show QR Code button */
        .show-qr-btn {
            background: linear-gradient(45deg, #00802b, #00802b); /* Green gradient */
            border: none;
            color: white;
            padding: 0.4rem 0.75rem;
            font-size: 0.875rem;
            border-radius: 4px;
            transition: background 0.3s ease;
        }

            .show-qr-btn:hover {
                background: linear-gradient(45deg, #388E3C, #66BB6A); /* Darker green on hover */
            }

        /* Fixed column widths and word wrapping */
        table {
            table-layout: fixed;
            width: 100%;
        }

        th,
        td {
            word-wrap: break-word;
            white-space: normal; /* Ensures text wraps inside the cell */
            vertical-align: middle;
        }

            /* Adjusted width for QuizStart and QuizEnd columns to just fit the datetime */
            th.date-time,
            td.date-time {
                width: 10%; /* Adjust this percentage to just enough to fit the datetime */
                white-space: nowrap; /* Prevents unnecessary wrapping */
            }

        th {
            width: 30%; /* Set fixed width for other columns */
        }

            th.actions,
            td.actions {
                width: 25%; /* Slightly smaller for actions */
            }
    </style>

</head>

<body>
    <main id="main" class="main">
        <section class="section dashboard">
            <div class="row">
                <div class="col-12">
                    <div class="row">
                        <div class="col-xxl-12 col-md-12">
                            <div class="card info-card customers-card">
                                <div class="card-header d-flex justify-content-between">
                                    <h class="card-title">All Quizzes</h>
                                    <a href="@Url.Action("Create", "Quizzes")" class="btn btn-primary btn-sm" id="create-btn">
                                        Create Quiz
                                    </a>
                                </div>
                                <div class="card-body">
                                    <div class="form-container">

                                        @if (TempData["SuccessMessage"] != null)
                                        {
                                            <div class="alert alert-success">
                                                @TempData["SuccessMessage"]
                                            </div>
                                        }

                                        @if (TempData["ErrorMessage"] != null)
                                        {
                                            <div class="alert alert-danger">
                                                <span>@TempData["ErrorMessage"]</span>
                                            </div>
                                        }

                                        <!-- Upcoming Quizzes Section -->
                                        <div class="table-section">
                                            <h5 class="section-title">Upcoming Quizzes</h5>
                                            <input type="text" id="searchUpcomingInput" class="form-control search-input" placeholder="Search upcoming quizzes...">

                                            @if (Model.Quizzes.Where(q => q.QuizEnd > DateTime.Now).OrderByDescending(q => q.QuizStart).Any())
                                            {
                                                <div class="table-container">
                                                    <table class="table table-bordered table-striped" id="upcomingQuizTable">
                                                        <thead class="table-dark">
                                                            <tr>
                                                                <th>Quiz Title</th>
                                                                <th>Description</th>
                                                                <th class="date-time">Quiz Start</th>
                                                                <th class="date-time">Quiz End</th>
                                                                <th class="actions">Actions</th>
                                                            </tr>
                                                        </thead>
                                                        <tbody>
                                                            @foreach (var quiz in Model.Quizzes.Where(q => q.QuizEnd > DateTime.Now).OrderByDescending(q => q.QuizStart))
                                                            {
                                                                <tr>
                                                                    <td>@quiz.Title</td>
                                                                    <td>@quiz.Description</td>
                                                                    <td class="date-time">@quiz.QuizStart.ToString("yyyy-MM-dd HH:mm")</td>
                                                                    <td class="date-time">@quiz.QuizEnd.ToString("yyyy-MM-dd HH:mm")</td>
                                                                    <td class="actions">
                                                                        <a href="@Url.Action("Details", "Quizzes", new { id = quiz.QuizID })" class="btn btn-primary btn-sm">
                                                                            View Details
                                                                        </a>
                                                                        <button type="button" class="btn show-qr-btn" data-quiz-id="@quiz.QuizID" data-bs-toggle="modal" data-bs-target="#qrModal">
                                                                            Show QR Code
                                                                        </button>
                                                                        <form asp-action="Delete" method="post" onsubmit="return confirm('Are you sure you want to delete this quiz?');" style="display:inline-block;">
                                                                            <input type="hidden" name="id" value="@quiz.QuizID" />
                                                                            @Html.AntiForgeryToken()
                                                                            <button type="submit" class="btn btn-danger btn-sm">
                                                                                <i class="bi bi-trash"></i> Delete
                                                                            </button>
                                                                        </form>
                                                                    </td>
                                                                </tr>
                                                            }
                                                        </tbody>
                                                    </table>
                                                </div>
                                            }
                                            else
                                            {
                                                <div class="no-quiz-container">
                                                    <i class="bi bi-calendar-x icon"></i>
                                                    <h5>No Upcoming Quizzes Available</h5>
                                                    <a href="@Url.Action("Create", "Quizzes")" class="btn btn-primary btn-sm">Create Quiz</a>
                                                </div>
                                            }
                                        </div>

                                        <!-- Past Quizzes Section -->
                                        <div class="table-section">
                                            <h5 class="section-title">Past Quizzes</h5>
                                            <input type="text" id="searchPastInput" class="form-control search-input" placeholder="Search past quizzes...">

                                            @if (Model.Quizzes.Where(q => q.QuizEnd < DateTime.Now).OrderByDescending(q => q.QuizEnd).Any())
                                            {
                                                <div class="table-container">
                                                    <table class="table table-bordered table-striped" id="pastQuizTable">
                                                        <thead class="table-dark">
                                                            <tr>
                                                                <th>Quiz Title</th>
                                                                <th>Description</th>
                                                                <th>Quiz Start</th>
                                                                <th>Quiz End</th>
                                                                <th>Actions</th>
                                                            </tr>
                                                        </thead>
                                                        <tbody>
                                                            @foreach (var quiz in Model.Quizzes.Where(q => q.QuizEnd < DateTime.Now).OrderByDescending(q => q.QuizEnd))
                                                            {
                                                                <tr>
                                                                    <td>@quiz.Title</td>
                                                                    <td>@quiz.Description</td>
                                                                    <td>@quiz.QuizStart.ToString("yyyy-MM-dd HH:mm")</td>
                                                                    <td>@quiz.QuizEnd.ToString("yyyy-MM-dd HH:mm")</td>
                                                                    <td>
                                                                        <a href="@Url.Action("Details", "Quizzes", new { id = quiz.QuizID })" class="btn btn-primary btn-sm">
                                                                            View Details
                                                                        </a>
                                                                        <button type="button" class="btn show-qr-btn" data-quiz-id="@quiz.QuizID" data-bs-toggle="modal" data-bs-target="#qrModal">
                                                                            Show QR Code
                                                                        </button>
                                                                        <form asp-action="Delete" method="post" onsubmit="return confirm('Are you sure you want to delete this quiz?');" style="display:inline-block;">
                                                                            <input type="hidden" name="id" value="@quiz.QuizID" />
                                                                            @Html.AntiForgeryToken()
                                                                            <button type="submit" class="btn btn-danger btn-sm">
                                                                                <i class="bi bi-trash"></i> Delete
                                                                            </button>
                                                                        </form>
                                                                    </td>
                                                                </tr>
                                                            }
                                                        </tbody>
                                                    </table>
                                                </div>
                                            }
                                            else
                                            {
                                                <div class="no-quiz-container">
                                                    <i class="bi bi-calendar-x icon"></i>
                                                    <h5>No Past Quizzes Available</h5>
                                                </div>
                                            }
                                        </div>

                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div><!-- End Left side columns -->
            </div>
        </section>
    </main>

    <!-- QR Code Modal -->
    <div class="modal fade" id="qrModal" tabindex="-1" aria-labelledby="qrModalLabel" aria-hidden="true">
        <div class="modal-dialog modal-lg modal-dialog-centered">
            <!-- Set modal to large size -->
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title" id="qrModalLabel">Quiz QR Code</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body text-center">
                    <div id="qrCode"></div> <!-- QR code container -->
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
                </div>
            </div>
        </div>
    </div>

    <script>
        // Filter Upcoming Quizzes
        $(document).ready(function () {
            $('#searchUpcomingInput').on('keyup', function () {
                var value = $(this).val().toLowerCase();
                $('#upcomingQuizTable tbody tr').filter(function () {
                    $(this).toggle($(this).text().toLowerCase().indexOf(value) > -1)
                });
            });

            // Filter Past Quizzes
            $('#searchPastInput').on('keyup', function () {
                var value = $(this).val().toLowerCase();
                $('#pastQuizTable tbody tr').filter(function () {
                    $(this).toggle($(this).text().toLowerCase().indexOf(value) > -1)
                });
            });

            // Show QR Code in Modal
            $('.show-qr-btn').on('click', function () {
                var quizId = $(this).data('quiz-id');
                $('#qrCode').empty(); // Clear any previous QR code
                new QRCode(document.getElementById("qrCode"), {
                    text: quizId,  // Quiz ID GUID as text
                    width: 600,   // Increased size (2x)
                    height: 600   // Increased size (2x)
                });
            });
        });
    </script>
</body>

</html>
