@model PKFAuditManagement.ViewModels.QuizViewModel

<head>
    <style>
        .form-container {
            padding: 20px;
        }

        .btn-primary,
        .btn-secondary,
        .btn-danger {
            padding: 0.5rem 1rem;
        }

        .btn-edit {
            float: right;
            margin-left: 1rem;
        }

        .card {
            margin-bottom: 1rem;
            padding: 1rem;
        }

        .card-title {
            margin-bottom: 1rem;
        }

        .nav-tabs {
            display: flex;
            border-bottom: 1px solid #dee2e6;
        }

        .nav-item {
            margin-bottom: -1px;
        }

        .nav-link {
            border: 1px solid transparent;
            border-top-left-radius: .25rem;
            border-top-right-radius: .25rem;
        }

            .nav-link.active {
                color: #495057;
                background-color: #fff;
                border-color: #dee2e6 #dee2e6 #fff;
            }

        .tab-content {
            flex-grow: 1;
            padding: 1rem;
            border: 1px solid #dee2e6;
            border-top: none;
        }

        .qrcode-container {
            display: flex;
            justify-content: center;
            align-items: center;
            height: auto;
            padding: 20px;
        }

            .qrcode-container img {
                width: 100%;
                max-width: 600px;
            }

        .filter-tabs {
            margin-bottom: 1rem;
        }

            .filter-tabs .nav-link {
                cursor: pointer;
            }

        .card-participant {
            margin-bottom: 1rem;
            padding: 1rem;
        }

            .card-participant .card-body {
                display: flex;
                justify-content: space-between;
                align-items: center;
            }

                .card-participant .card-body .participant-info {
                    flex-grow: 1;
                }

                .card-participant .card-body .participant-score {
                    margin-left: 1rem;
                    text-align: right;
                }

        #border_tab {
            border: 1px solid transparent;
        }

        .email-button-container {
            display: flex;
            justify-content: flex-end;
            margin-bottom: 1rem;
        }
    </style>
</head>
<main id="main" class="main">
    <div class="pagetitle">
        <h1>Quiz Details</h1>
    </div>

    <section class="section dashboard">
        <div class="row">
            <div class="col-12">
                @if (TempData["SuccessMessage"] != null)
                {
                    <div class="alert alert-success">
                        @TempData["SuccessMessage"]
                    </div>
                }

                <ul class="nav nav-tabs" id="quizTabs" role="tablist">
                    <li class="nav-item" role="presentation">
                        <button class="nav-link active" id="details-tab" data-bs-toggle="tab" data-bs-target="#details" type="button" role="tab" aria-controls="details" aria-selected="true">View Quiz Details</button>
                    </li>
                    <li class="nav-item" role="presentation">
                        <button class="nav-link" id="participants-tab" data-bs-toggle="tab" data-bs-target="#participants" type="button" role="tab" aria-controls="participants" aria-selected="false">View Participants</button>
                    </li>
                    <li class="nav-item" role="presentation">
                        <button class="nav-link" id="qr-code-tab" data-bs-toggle="tab" data-bs-target="#qr-code" type="button" role="tab" aria-controls="qr-code" aria-selected="false">Generate QR Code</button>
                    </li>
                </ul>

                <div class="tab-content" id="quizTabsContent">
                    <div class="tab-pane fade show active" id="details" role="tabpanel" aria-labelledby="details-tab">
                        <h5 class="card-title d-flex justify-content-between align-items-center">
                            Quiz: @Model.Title
                            <a asp-action="Edit" asp-route-id="@Model.QuizID" class="btn btn-primary btn-sm btn-edit">Edit Quiz</a>
                        </h5>
                        <p>@Model.Description</p>

                        @foreach (var question in Model.Questions)
                        {
                            <div class="card mb-3">
                                <div class="card-body">
                                    <h5 class="card-title">Question: @question.Description</h5>
                                    <ul class="list-group list-group-flush">
                                        @foreach (var option in question.Options)
                                        {
                                            <li class="list-group-item">@option.OptionText</li>
                                        }
                                    </ul>
                                    <p class="mt-2"><strong>Correct Option:</strong> @question.CorrectOptionText</p>
                                </div>
                            </div>
                        }
                    </div>
                    <div class="tab-pane fade" id="qr-code" role="tabpanel" aria-labelledby="qr-code-tab">
                        <h5 class="card-title">Generate QR Code</h5>
                        <p>QR Code for Quiz ID: @Model.QuizID</p>
                        <div class="qrcode-container">
                            <div id="qrcode"></div>
                        </div>
                    </div>
                    <div class="tab-pane fade" id="participants" role="tabpanel" aria-labelledby="participants-tab">
                        <h5 class="card-title">Participants</h5>
                        <ul class="nav nav-pills filter-tabs" id="participantFilterTabs" role="tablist">
                            <li class="nav-item">
                                <a class="nav-link active" data-bs-toggle="pill" href="#all-participants" role="tab" aria-controls="all-participants" aria-selected="true">All</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" data-bs-toggle="pill" href="#passed-participants" role="tab" aria-controls="passed-participants" aria-selected="false">Passed</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" data-bs-toggle="pill" href="#failed-participants" role="tab" aria-controls="failed-participants" aria-selected="false">Failed</a>
                            </li>
                        </ul>

                        <div class="tab-content" id="border_tab">
                            <div class="tab-pane fade show active" id="all-participants" role="tabpanel">
                                @if (!Model.Participants.Any())
                                {
                                    <p>No participants available for this quiz.</p>
                                }
                                else
                                {
                                    @foreach (var participant in Model.Participants)
                                    {
                                        <div class="card card-participant" data-score="@participant.TotalScore">
                                            <div class="card-body">
                                                <div class="participant-info">
                                                    <p>Participant: @participant.UserName</p>
                                                    <p>Email: @participant.Email</p> <!-- Display Email -->
                                                    <p>Attempted on: @participant.AttemptDate.ToString("yyyy-MM-dd HH:mm")</p>
                                                </div>
                                                <div class="participant-score">
                                                    <p class="text-end"><strong>Score: @participant.TotalScore / @ViewBag.TotalQuestions</strong></p>
                                                </div>
                                            </div>
                                        </div>
                                    }
                                }
                            </div>
                            <div class="tab-pane fade" id="passed-participants" role="tabpanel">
                                @if (!Model.Participants.Any(p => p.TotalScore >= @ViewBag.TotalQuestions * 0.5))
                                {
                                    <p>No participants passed the quiz.</p>
                                }
                                else
                                {
                                    @foreach (var participant in Model.Participants.Where(p => p.TotalScore >= @ViewBag.TotalQuestions * 0.5))
                                    {
                                        <div class="card card-participant" data-score="@participant.TotalScore">
                                            <div class="card-body">
                                                <div class="participant-info">
                                                    <p>Participant: @participant.UserName</p>
                                                    <p>Email: @participant.Email</p> <!-- Display Email -->
                                                    <p>Attempted on: @participant.AttemptDate.ToString("yyyy-MM-dd HH:mm")</p>
                                                </div>
                                                <div class="participant-score">
                                                    <p class="text-end"><strong>Score: @participant.TotalScore / @ViewBag.TotalQuestions</strong></p>
                                                </div>
                                            </div>
                                        </div>
                                    }
                                }
                            </div>
                            <div class="tab-pane fade" id="failed-participants" role="tabpanel">
                                <div class="email-button-container">
                                    <button id="emailFailedParticipants" class="btn btn-primary">Email Failed Participants</button>
                                </div>
                                @if (!Model.Participants.Any(p => p.TotalScore < @ViewBag.TotalQuestions * 0.5))
                                {
                                    <p>No participants failed the quiz.</p>
                                }
                                else
                                {
                                    @foreach (var participant in Model.Participants.Where(p => p.TotalScore < @ViewBag.TotalQuestions * 0.5))
                                    {
                                        <div class="card card-participant" data-score="@participant.TotalScore">
                                            <div class="card-body">
                                                <div class="participant-info">
                                                    <p>Participant: @participant.UserName</p>
                                                    <p>Email: @participant.Email</p> <!-- Display Email -->
                                                    <p>Attempted on: @participant.AttemptDate.ToString("yyyy-MM-dd HH:mm")</p>
                                                </div>
                                                <div class="participant-score">
                                                    <p class="text-end"><strong>Score: @participant.TotalScore / @ViewBag.TotalQuestions</strong></p>
                                                </div>
                                            </div>
                                        </div>
                                    }
                                }
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>
</main>
<script>
    document.addEventListener("DOMContentLoaded", function () {
        fetch(`@Url.Action("GenerateQR", "Quizzes")?quizId=@Model.QuizID`)
            .then(response => response.json())
            .then(data => {
                var qrcodeContainer = document.getElementById("qrcode");
                if (qrcodeContainer) {
                    var img = document.createElement("img");
                    img.src = data.qrCodeImage;
                    img.style.width = "600px"; // Adjust width as needed
                    img.style.height = "600px"; // Adjust height as needed
                    qrcodeContainer.appendChild(img);
                }
            })
            .catch(error => console.error('Error generating QR code:', error));

        var emailButton = document.getElementById("emailFailedParticipants");
        if (emailButton) {
            emailButton.addEventListener("click", function () {
                var failedEmails = @Html.Raw(ViewBag.FailedParticipantsEmails);
                var subject = "Quiz Review";
                var body = "Please review your quiz performance.";
                var mailtoLink = "mailto:" + failedEmails.join(",") + "?subject=" + encodeURIComponent(subject) + "&body=" + encodeURIComponent(body);
                window.location.href = mailtoLink;
            });
        }
    });
</script>