@model PKFAuditManagement.ViewModels.QuizViewModel

<!DOCTYPE html>
<html lang="en">

<head>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdnjs.cloudflare.com/ajax/libs/bootstrap-icons/1.8.1/font/bootstrap-icons.min.css" rel="stylesheet">
    <style>
        .form-container {
            padding: 20px;
        }

        .btn-primary,
        .btn-secondary,
        .btn-danger {
            padding: 0.5rem 1rem;
        }

        .btn-edit {
            float: right;
            margin-left: 1rem;
        }

        .card {
            margin-bottom: 1rem;
            padding: 1rem;
        }

        .card-title {
            margin-bottom: 1rem;
        }

        .nav-tabs {
            display: flex;
            border-bottom: 1px solid #dee2e6;
        }

        .nav-item {
            margin-bottom: -1px;
        }

        .nav-link {
            border: 1px solid transparent;
            border-top-left-radius: .25rem;
            border-top-right-radius: .25rem;
        }

            .nav-link.active {
                color: #495057;
                background-color: #fff;
                border-color: #dee2e6 #dee2e6 #fff;
            }

        .tab-content {
            flex-grow: 1;
            padding: 1rem;
            border: 1px solid #dee2e6;
            border-top: none;
        }

        .qrcode-container {
            display: flex;
            justify-content: center;
            align-items: center;
            height: auto;
            padding: 20px;
        }

            .qrcode-container img {
                width: 100%;
                max-width: 600px;
            }
    </style>
</head>

<body>
    <main id="main" class="main">
        <div class="pagetitle">
            <h1>Quiz Details</h1>
        </div>

        <section class="section dashboard">
            <div class="row">
                <div class="col-12">
                    @if (TempData["SuccessMessage"] != null)
                    {
                        <div class="alert alert-success">
                            @TempData["SuccessMessage"]
                        </div>
                    }

                    <ul class="nav nav-tabs" id="quizTabs" role="tablist">
                        <li class="nav-item" role="presentation">
                            <button class="nav-link active" id="details-tab" data-bs-toggle="tab" data-bs-target="#details" type="button" role="tab" aria-controls="details" aria-selected="true">View Quiz Details</button>
                        </li>
                        <li class="nav-item" role="presentation">
                            <button class="nav-link" id="qr-code-tab" data-bs-toggle="tab" data-bs-target="#qr-code" type="button" role="tab" aria-controls="qr-code" aria-selected="false">Generate QR Code</button>
                        </li>
                    </ul>

                    <div class="tab-content" id="quizTabsContent">
                        <div class="tab-pane fade show active" id="details" role="tabpanel" aria-labelledby="details-tab">
                            <h5 class="card-title d-flex justify-content-between align-items-center">
                                Quiz: @Model.Title
                                @if (Model.CanEdit)
                                {
                                    <a asp-action="Edit" asp-route-id="@Model.QuizID" class="btn btn-primary btn-sm btn-edit">Edit Quiz</a>
                                }
                            </h5>
                            <p>@Model.Description</p>

                            @foreach (var question in Model.Questions.Select((q, index) => new { q, index }))
                            {
                                <div class="card mb-3">
                                    <div class="card-body">
                                        <h5 class="card-title">Question @(question.index + 1) : @question.q.Description</h5>
                                        <ul class="list-group list-group-flush">
                                            @foreach (var option in question.q.Options)
                                            {
                                                <li class="list-group-item">@option.OptionText</li>
                                            }
                                        </ul>
                                        <p class="mt-2"><strong>Correct Option:</strong> @question.q.CorrectOptionText</p>
                                    </div>
                                </div>
                            }
                        </div>
                        <div class="tab-pane fade" id="qr-code" role="tabpanel" aria-labelledby="qr-code-tab">
                            <h5 class="card-title">Generate QR Code</h5>
                            <p>QR Code for Quiz ID: @Model.QuizID</p>
                            <div class="qrcode-container">
                                <div id="qrcode"></div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </section>
    </main>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        document.addEventListener("DOMContentLoaded", function () {
            fetch(`@Url.Action("GenerateQR", "Quizzes")?quizId=@Model.QuizID`)
                .then(response => response.json())
                .then(data => {
                    var qrcodeContainer = document.getElementById("qrcode");
                    if (qrcodeContainer) {
                        var img = document.createElement("img");
                        img.src = data.qrCodeImage;
                        img.style.width = "600px"; // Adjust width as needed
                        img.style.height = "600px"; // Adjust height as needed
                        qrcodeContainer.appendChild(img);
                    }
                })
                .catch(error => console.error('Error generating QR code:', error));
        });
    </script>
</body>

</html>
