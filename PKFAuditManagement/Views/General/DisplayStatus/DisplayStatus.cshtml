@model IEnumerable<PKFAuditManagement.ViewModels.DisplayStatusViewModel>

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Display Status</title>
    <link rel="stylesheet" href="~/css/site.css">
    <link rel="stylesheet" href="https://cdn.datatables.net/1.13.4/css/jquery.dataTables.min.css">
</head>
<body>
    <main id="main" class="main">
        <div class="pagetitle">
            <h1>Display Status</h1>
        </div>

        <section class="section">
            <div class="row">
                <div class="col-lg-12">
                    <div class="card">
                        <div class="card-body">
                            <h5 class="card-title">Client Form Statuses</h5>

                            <table class="table table-striped">
                                <thead>
                                    <tr>
                                        <th>Client Name</th>
                                        <th>Financial Year End</th> <!-- New column -->
                                        <th>QC6 First Approver</th> <!-- New column -->
                                        <th>QC6 Second Approver</th> <!-- New column -->
                                        <th>QC7 First Approver</th> <!-- New column -->
                                        <th>QC7 Second Approver</th> <!-- New column -->
                                        <th>SignedFS Status</th> <!-- New column -->
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var item in Model)
                                    {
                                            <tr>
                                                <td>@item.ClientName</td>
                                                <td>@item.FinancialYearEnd?.ToShortDateString()</td> <!-- Added Financial Year End -->

                                                <td>
                                                @if (!string.IsNullOrEmpty(item.QC6FirstApprover))
                                                {
                                                    @item.QC6FirstApprover
                                                }
                                                else
                                                {
                                                            <span class="badge bg-secondary">N/A</span>
                                                }
                                                </td>
                                                <td>
                                                @if (!string.IsNullOrEmpty(item.QC6SecondApprover))
                                                {
                                                    @item.QC6SecondApprover
                                                }
                                                else
                                                {
                                                            <span class="badge bg-secondary">N/A</span>
                                                }
                                                </td>

                                                <td>
                                                @if (!string.IsNullOrEmpty(item.QC7FirstApprover))
                                                {
                                                    @item.QC7FirstApprover
                                                }
                                                else
                                                {
                                                            <span class="badge bg-secondary">N/A</span>
                                                }
                                                </td>
                                                <td>
                                                @if (!string.IsNullOrEmpty(item.QC7SecondApprover))
                                                {
                                                    @item.QC7SecondApprover
                                                }
                                                else
                                                {
                                                            <span class="badge bg-secondary">N/A</span>
                                                }
                                                </td>

                                                <td>
                                                @if (item.SignedFSStatus == "Processed")
                                                {
                                                            <span class="badge bg-success">Uploaded</span>
                                                }
                                                else
                                                {
                                                            <span class="badge bg-secondary">Not Uploaded</span>
                                                }
                                                </td>
                                            </tr>
                                    }
                                </tbody>
                            </table>

                        </div>
                    </div>
                </div>
            </div>
        </section>
    </main>
</body>
</html>
