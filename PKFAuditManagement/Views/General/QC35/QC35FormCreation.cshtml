@model PKFAuditManagement.ViewModels.QC35FormViewModel

<div class="justify-content-center">
    <main id="main" class="main">
        <div class="pagetitle">
            <h1>Form QC35</h1>
        </div><!-- End Page Title -->
        <section class="section">
            <div class="row">
                <div class="col-lg-12">
                    <form id="mainForm" asp-action="SubmitQC35Form" asp-controller="QC35Form" method="post" enctype="multipart/form-data">
                        @if (ViewBag.Errors != null)
                        {
                            <ul>
                                @foreach (var error in ViewBag.Errors)
                                {
                                    <li>@error.ErrorMessage</li>
                                }
                            </ul>
                        }
                        else if (ViewBag.ErrorMessage != null)
                        {
                            <span class="alert alert-danger">@ViewBag.ErrorMessage</span>
                        }
                        @if (Model.AdminEmails != null && Model.AdminEmails.Any())
                        {
                            @for (int i = 0; i < Model.AdminEmails.Count; i++)
                            {
                                <input type="hidden" name="AdminEmails[@i]" value="@Model.AdminEmails[i]" />
                            }
                        }
                        <div class="card">
                            <div class="card-body">
                                <h5 class="card-title">File Archival Form</h5>
                                <span class="text-danger">* indicates a mandatory field</span>
                                <br><br>
                                @Html.AntiForgeryToken()
                                <div class="form-group">
                                    <label asp-for="ClientName">Client Name:<span class="text-danger"> *</span></label>
                                    <div class="input-group">
                                        <select asp-for="ClientName" class="form-control">
                                            @if (Model.ClientNames != null && Model.ClientNames.Any())
                                            {
                                                @foreach (var client in Model.ClientNames)
                                                {
                                                    <option value="@client">@client</option>
                                                }
                                            }
                                            else
                                            {
                                                <option disabled>No clients available</option>
                                            }
                                        </select>
                                        <span asp-validation-for="ClientName" class="text-danger"></span>
                                    </div>
                                </div>
                                <div class="form-group">
                                    <label asp-for="ReportingYearEnd">Reporting Year End:<span class="text-danger"> *</span></label>
                                    <div class="input-group">
                                        <input type="date" class="form-control" asp-for="ReportingYearEnd" id="reportingYearEnd">
                                        <span asp-validation-for="ReportingYearEnd" class="text-danger"></span>
                                    </div>
                                </div>
                                <div class="form-group">
                                    <label asp-for="ClientName">Approved by (Manager):<span class="text-danger"> *</span></label>
                                    <div class="input-group">
                                        @if (Model.AdminEmails != null && Model.AdminEmails.Any())
                                        {
                                            <select asp-for="ManagerName" class="form-control">
                                                @foreach (var email in Model.AdminEmails)
                                                {
                                                    <option value="@email">@email</option>
                                                }
                                            </select>
                                        }
                                        else
                                        {
                                            <span class="text-danger">No admin emails available</span>
                                        }
                                        <span asp-validation-for="ManagerName" class="text-danger"></span>
                                    </div>
                                </div>
                                <div class="form-group">
                                    <label asp-for="ClientName">Approved by (Partner):<span class="text-danger"> *</span></label>
                                    <div class="input-group">
                                        @if (Model.AdminEmails != null && Model.AdminEmails.Any())
                                        {
                                            <select asp-for="PartnerName" class="form-control">
                                                @foreach (var email in Model.AdminEmails)
                                                {
                                                    <option value="@email">@email</option>
                                                }
                                            </select>
                                        }
                                        else
                                        {
                                            <span class="text-danger">No admin emails available</span>
                                        }
                                        <span asp-validation-for="PartnerName" class="text-danger"></span>
                                    </div>
                                </div>

                                <style>
                                    .form-group {
                                        display: flex;
                                        flex-wrap: nowrap;
                                        align-items: center;
                                        margin-bottom: 1rem;
                                    }

                                        .form-group label {
                                            width: 17%;
                                            margin-bottom: 0;
                                            margin-right: 2.5em;
                                        }

                                        .form-group .input-group {
                                            display: flex;
                                            flex-wrap: nowrap;
                                            width: 84%;
                                        }

                                        .input-group > .form-control {
                                            flex: 1;
                                            margin-right: 0.5rem;
                                        }

                                        .input-group > .form-control:last-child {
                                            margin-right: 0;
                                        }

                                    .imageUpload {
                                        width: 100%;
                                        display: flex;
                                        align-items: center;
                                        justify-content: center;
                                    }

                                    #drop-area {
                                        width: 100%;
                                        padding: 30px;
                                        background: #fff;
                                        text-align: center;
                                        border-radius: 20px;
                                        border: 2px dashed #bbb5ff;
                                        display: flex;
                                        flex-direction: column;
                                        align-items: center;
                                        justify-content: center;
                                    }

                                    #img-view {
                                        width: 100%;
                                        border-radius: 20px;
                                        background: #f7f8ff;
                                        background-position: center;
                                        background-size: cover;
                                        background-repeat: no-repeat;
                                        transition: height 0.3s ease;
                                    }

                                        #img-view img {
                                            width: 100px;
                                            margin-top: 25px;
                                        }

                                        #img-view span {
                                            display: block;
                                            font-size: 12px;
                                            color: #777;
                                            margin-top: 15px;
                                        }

                                </style>

                                <div class="table-responsive" id="tableContainer">
                                    <table class="table table-bordered table-striped">
                                        <thead class="table-light" style="background-color: #f8f9fa;">
                                            <tr>
                                                <th class="text-left pl-3 text-uppercase" style="width: 30%;">Checklist - Description</th>
                                                <th class="text-left text-uppercase" style="width: 40%;">Response</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            @for (int i = 0; i < Model.ChecklistItems.Count; i++)
                                            {
                                                <tr class="text-zinc-700 dark:text-zinc-400">
                                                    <td>
                                                        <div>
                                                            <p>@Model.ChecklistItems[i].Description</p>
                                                            <input type="hidden" name="ChecklistItems[@i].Description" value="@Model.ChecklistItems[i].Description" />
                                                        </div>
                                                    </td>
                                                    <td>
                                                        @if (Model.ChecklistItems[i].Description == "Date of Audit Report" ||
                                                       Model.ChecklistItems[i].Description == "Date of approval and confirmation that CaseWare Audit files has been locked down within 60 days from the date of the Audit Report (if applicable). Refer to the screenshot of CaseWare below.")
                                                        {
                                                            <input type="date" class="form-control" name="ChecklistItems[@i].Response" asp-for="@Model.ChecklistItems[i].Response" required />
                                                        }
                                                        else
                                                        {
                                                            <input type="text" class="form-control" name="ChecklistItems[@i].Response" asp-for="@Model.ChecklistItems[i].Response" value="" required />
                                                        }

                                                    </td>
                                                </tr>
                                            }
                                        </tbody>
                                    </table>
                                </div>
                                <div class="imageUpload">
                                    <label for="input-file" id="drop-area">
                                        <input type="file" name="file" accept="image/*" id="input-file" hidden>
                                        <div id="img-view">
                                            <img src="~/img/upload-icon.png" alt="Upload Icon">
                                            <p>Drag and drop or click here<br>to upload image</p>
                                            <span>Upload any images from desktop</span>
                                        </div>
                                    </label>
                                </div>

                                <div class="text-center">
                                    <button id="cancel-upload" type="button" class="btn btn-danger mt-3" style="display:none;">Cancel Upload</button>
                                    <button id="crop-image-button" type="button" class="btn btn-success mt-3" style="display:none;">Crop Image</button>
                                    <button type="submit" class="mt-3 end-0 btn btn-primary">Submit QC35 Form</button>
                                </div>

                                <canvas id="canvas" style="display:none;"></canvas>

                            </div>
                        </div>
                    </form>
                </div>
            </div>
        </section>
    </main><!-- End #main -->
</div>
<a href="#" class="back-to-top d-flex align-items-center justify-content-center"><i class="bi bi-arrow-up-short"></i></a>

@section Scripts {

    <script>
        let cropper;
        const dropArea = document.getElementById("drop-area");
        const inputFile = document.getElementById("input-file");
        const imageView = document.getElementById("img-view");
        const cropButton = document.getElementById("crop-button");
        const cancelButton = document.getElementById("cancel-upload");
        const cropImageButton = document.getElementById("crop-image-button");
        const form = document.querySelector("mainForm");

        // Get the image path using Razor syntax and inject it into the JavaScript as a constant
        const uploadIconPath = '@Url.Content("~/img/upload-icon.png")';

        cropImageButton.addEventListener("click", function () {
            if (cropper) {
                cropper.getCroppedCanvas().toBlob((blob) => {
                    // Create a new File object
                    const croppedImage = new File([blob], "cropped-image.jpg", { type: "image/jpeg" });

                    // Create a new FileList containing the cropped image
                    const dataTransfer = new DataTransfer();
                    dataTransfer.items.add(croppedImage);

                    // Update the file input with the new FileList
                    inputFile.files = dataTransfer.files;

                    // Optionally, update the image preview by adding <img> instead of backgroundImage
                    const croppedImageUrl = URL.createObjectURL(croppedImage);
                    imageView.innerHTML = ""; // Clear previous content

                    // Create an img element and append it to the imageView
                    const imgElement = document.createElement("img");
                    imgElement.src = croppedImageUrl;
                    imgElement.style.maxWidth = "100%";
                    imgElement.style.borderRadius = "20px";
                    imageView.appendChild(imgElement);

                    console.log("Image cropped and input updated");
                }, 'image/jpeg');
            } else {
                console.log("Cropper not initialized");
            }
        });

        // Add event listener for file selection
        inputFile.addEventListener("change", handleFileSelect);
        // Add event listener for cancel upload
        cancelButton.addEventListener("click", cancelUpload);

        function handleFileSelect(event) {
            const file = event.target.files[0];
            if (file) {
                const imgLink = URL.createObjectURL(file);
                imageView.style.backgroundImage = `url(${imgLink})`;
                imageView.style.height = "500px";
                imageView.innerHTML = ""; // Clear the previous content

                const imgElement = document.createElement("img");
                imgElement.src = imgLink;
                imgElement.id = "uploaded-image";
                imgElement.style.maxWidth = "100%";
                imageView.appendChild(imgElement);

                imgElement.onload = function () {
                    try {
                        // Initialize Cropper.js
                        cropper = new Cropper(imgElement, {
                            aspectRatio: NaN, // or set to desired aspect ratio
                            viewMode: 1
                        });
                    } catch (error) {
                        console.error("Error initializing Cropper:", error);
                    }
                };
                cancelButton.style.display = "inline-block";  // Show cancel button
                cropImageButton.style.display = "inline-block";  // Show crop button
                disableUpload();  // Disable upload functionality
            }
        }

        // Function to disable both click and drag-and-drop functionality
        function disableUpload() {
            inputFile.disabled = true; // Disable click-to-upload
            dropArea.removeEventListener("drop", handleDrop); // Remove drop event listener
            dropArea.classList.add('upload-disabled'); // Add a class for styling
        }

        // Function to enable both click and drag-and-drop functionality (for cancel)
        function enableUpload() {
            dropArea.style.pointerEvents = "auto"; // Re-enable drag-and-drop
            inputFile.disabled = false; // Re-enable click-to-upload
        }

        // Drag and drop functionality
        dropArea.addEventListener("dragover", function (e) {
            if (dropArea.style.pointerEvents === "none") {
                return; // Prevent drag if pointer-events is set to none
            }
            e.preventDefault();
        });

        dropArea.addEventListener("drop", function (e) {
            if (dropArea.style.pointerEvents === "none") {
                return; // Prevent drop if pointer-events is set to none
            }
            e.preventDefault();
            inputFile.files = e.dataTransfer.files;
            handleFileSelect({ target: { files: e.dataTransfer.files } });
        });

        // Function to cancel the upload and reset the image view
        function cancelUpload() {
            // Reset the image view content to show the upload icon and text
            imageView.style.backgroundImage = "";
            imageView.style.height = "auto";
            imageView.innerHTML = `
                                <img src="${uploadIconPath}" alt="Upload Icon">
                                <p>Drag and drop or click here<br>to upload image</p>
                                <span>Upload any images from desktop</span>
                            `;

            // Reset the file input
            inputFile.value = null;

            // Re-enable the input and drop functionality
            enableUpload();

            // Hide the cancel button
            cancelButton.style.display = "none";

            // Destroy the Cropper instance if it exists
            if (cropper) {
                cropper.destroy();
                cropper = null;
            }
        }

        document.addEventListener("DOMContentLoaded", function () {

            const dateInput = document.getElementById("reportingYearEnd");
            console.log("Date input: " + dateInput.value);
            // Function to set placeholder if the value is the default date
            function setPlaceholder() {
                if (dateInput.value === "0001-01-01") {
                    dateInput.value = "";
                }
            }

            // Set placeholder on load
            setPlaceholder();

            dateInput.addEventListener("focus", function () {
                dateInput.type = "date"; // Change to date type on focus
                if (dateInput.value === "0001-01-01") {
                    dateInput.value = ""; // Clear default value on focus
                }
            });

            dateInput.addEventListener("blur", function () {
                setPlaceholder();
            });

            const form = document.getElementById("mainForm");  // Select form by ID
            form.addEventListener("submit", function (e) {
                e.preventDefault();
                console.log("Form is submitted!");  // Debug log

                const formData = new FormData(this);

                // Append the cropped image file to the formData
                if (inputFile.files.length > 0) {
                    formData.append("file", inputFile.files[0]);
                }

                // Send form data via Fetch API
                fetch(this.action, {
                    method: 'POST',
                    body: formData
                })
                    .then(response => {
                        // Check if the response is JSON or something else
                        const contentType = response.headers.get("content-type");
                        if (contentType && contentType.includes("application/json")) {
                            return response.json();  // Parse JSON if it's a JSON response
                        } else {
                            return response.text();  // Handle non-JSON (e.g., HTML response)
                        }
                    })
                    .then(data => {
                        if (typeof data === "object") {
                            // JSON response, handle success
                            console.log('Success:', data);
                        } else {
                            // HTML response, most likely an error or redirect
                            console.log('HTML Response:', data);
                            document.body.innerHTML = data;  // Optionally display the HTML response
                        }
                    })
                    .catch((error) => {
                        console.error('Error:', error);
                    });
            });
        });


    </script>
}
