@model PKFAuditManagement.ViewModels.QC35FormViewModel

<div class="justify-content-center">
    <main id="main" class="main">
        <div class="pagetitle">
            <h1>Form QC35</h1>
        </div><!-- End Page Title -->
        <section class="section">
            <div class="row">
                <div class="col-lg-12">
                    <form id="mainForm" asp-action="SubmitQC35Form" asp-controller="QC35Form" method="post" enctype="multipart/form-data">
                        @if (ViewBag.Errors != null)
                        {
                            <ul>
                                @foreach (var error in ViewBag.Errors)
                                {
                                    <li>@error.ErrorMessage</li>
                                }
                            </ul>
                        }
                        else if (ViewBag.ErrorMessage != null)
                        {
                            <span class="alert alert-danger">@ViewBag.ErrorMessage</span>
                        }
                        @if (Model.AdminEmails != null && Model.AdminEmails.Any())
                        {
                            @for (int i = 0; i < Model.AdminEmails.Count; i++)
                            {
                                <input type="hidden" name="AdminEmails[@i]" value="@Model.AdminEmails[i]" />
                            }
                        }
                        <div class="card">
                            <div class="card-body">
                                <h5 class="card-title">File Archival Form</h5>
                                <span class="text-danger">* indicates a mandatory field</span>
                                <br><br>
                                @Html.AntiForgeryToken()
                                <div class="form-group">
                                    <label asp-for="ClientName">Client Name:<span class="text-danger"> *</span></label>
                                    <div class="input-group">
                                        <select asp-for="ClientName" class="form-control">
                                            @if (Model.ClientNames != null && Model.ClientNames.Any())
                                            {
                                                @foreach (var client in Model.ClientNames)
                                                {
                                                    <option value="@client">@client</option>
                                                }
                                            }
                                            else
                                            {
                                                <option disabled>No clients available</option>
                                            }
                                        </select>
                                        <span asp-validation-for="ClientName" class="text-danger"></span>
                                    </div>
                                </div>
                                <div class="form-group">
                                    <label asp-for="ReportingYearEnd">Reporting Year End:<span class="text-danger"> *</span></label>
                                    <div class="input-group">
                                        <input type="date" class="form-control" asp-for="ReportingYearEnd" id="reportingYearEnd">
                                        <span asp-validation-for="ReportingYearEnd" class="text-danger"></span>
                                    </div>
                                </div>
                                <div class="form-group">
                                    <label asp-for="ClientName">Approved by (Manager):<span class="text-danger"> *</span></label>
                                    <div class="input-group">
                                        @if (Model.AdminEmails != null && Model.AdminEmails.Any())
                                        {
                                            <select asp-for="ManagerName" class="form-control">
                                                @foreach (var email in Model.AdminEmails)
                                                {
                                                    <option value="@email">@email</option>
                                                }
                                            </select>
                                        }
                                        else
                                        {
                                            <span class="text-danger">No admin emails available</span>
                                        }
                                        <span asp-validation-for="ManagerName" class="text-danger"></span>
                                    </div>
                                </div>
                                <div class="form-group">
                                    <label asp-for="ClientName">Approved by (Partner):<span class="text-danger"> *</span></label>
                                    <div class="input-group">
                                        @if (Model.AdminEmails != null && Model.AdminEmails.Any())
                                        {
                                            <select asp-for="PartnerName" class="form-control">
                                                @foreach (var email in Model.AdminEmails)
                                                {
                                                    <option value="@email">@email</option>
                                                }
                                            </select>
                                        }
                                        else
                                        {
                                            <span class="text-danger">No admin emails available</span>
                                        }
                                        <span asp-validation-for="PartnerName" class="text-danger"></span>
                                    </div>
                                </div>

                                <style>
                                    .form-group {
                                        display: flex;
                                        flex-wrap: nowrap;
                                        align-items: center;
                                        margin-bottom: 1rem;
                                    }

                                        .form-group label {
                                            width: 17%;
                                            margin-bottom: 0;
                                            margin-right: 2.5em;
                                        }

                                        .form-group .input-group {
                                            display: flex;
                                            flex-wrap: nowrap;
                                            width: 84%;
                                        }

                                        .input-group > .form-control {
                                            flex: 1;
                                            margin-right: 0.5rem;
                                        }

                                        .input-group > .form-control:last-child {
                                            margin-right: 0;
                                        }

                                    .imageUpload {
                                        width: 100%;
                                        display: flex;
                                        align-items: center;
                                        justify-content: center;
                                    }

                                    #drop-area {
                                        width: 100%;
                                        padding: 30px;
                                        background: #fff;
                                        text-align: center;
                                        border-radius: 20px;
                                        border: 2px dashed #bbb5ff;
                                        display: flex;
                                        flex-direction: column;
                                        align-items: center;
                                        justify-content: center;
                                    }

                                    #img-view {
                                        width: 100%;
                                        height: 700px; /* Adjust based on your desired height */
                                        border-radius: 20px;
                                        background: #f7f8ff;
                                        display: flex;
                                        flex-direction: column; /* Stack elements vertically */
                                        align-items: center; /* Center elements horizontally */
                                        justify-content: center; /* Center elements vertically */
                                        overflow: hidden; /* Hide overflow for large images */
                                    }

                                    #upload-icon {
                                        margin-bottom: 20px; /* Add space below the icon */
                                    }

                                    #placeholder-text {
                                        text-align: center;
                                        font-size: 14px;
                                    }

                                    #uploaded-image {
                                        max-width: 100%; /* Scale image width */
                                        max-height: 100%; /* Scale image height */
                                        display: none; /* Hide initially until an image is uploaded */
                                    }

                                    #placeholder-text p,
                                    #placeholder-text span {
                                        margin: 0; /* Remove default margins */
                                        color: #777;
                                    }


                                        #img-view img {
                                            max-width: 100%; /* Scale image width */
                                            max-height: 100%; /* Scale image height */
                                            margin: 0 auto; /* Center image */
                                        }


                                        #img-view span {
                                            display: block;
                                            font-size: 12px;
                                            color: #777;
                                            margin-top: 15px;
                                        }

                                    #cancel-upload {
                                        display: none; /* Hidden by default */
                                    }

                                    #drop-area {
                                        transition: border-color 0.3s ease;
                                    }

                                        #drop-area.dragging {
                                            border-color: #4A90E2; /* Custom color when dragging over the area */
                                            background: #f1f7ff; /* Light background to indicate drop zone */
                                        }



                                </style>

                                <div class="table-responsive" id="tableContainer">
                                    <table class="table table-bordered table-striped">
                                        <thead class="table-light" style="background-color: #f8f9fa;">
                                            <tr>
                                                <th class="text-left pl-3 text-uppercase" style="width: 30%;">Checklist - Description</th>
                                                <th class="text-left text-uppercase" style="width: 40%;">Response</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            @for (int i = 0; i < Model.ChecklistItems.Count; i++)
                                            {
                                                <tr class="text-zinc-700 dark:text-zinc-400">
                                                    <td>
                                                        <div>
                                                            <p>@Model.ChecklistItems[i].Description</p>
                                                            <input type="hidden" name="ChecklistItems[@i].Description" value="@Model.ChecklistItems[i].Description" />
                                                        </div>
                                                    </td>
                                                    <td>
                                                        @if (Model.ChecklistItems[i].Description == "Date of Audit Report" ||
                                                       Model.ChecklistItems[i].Description == "Date of approval and confirmation that CaseWare Audit files has been locked down within 60 days from the date of the Audit Report (if applicable). Refer to the screenshot of CaseWare below.")
                                                        {
                                                            <input type="date" class="form-control" name="ChecklistItems[@i].Response" asp-for="@Model.ChecklistItems[i].Response" required />
                                                        }
                                                        else
                                                        {
                                                            <input type="text" class="form-control" name="ChecklistItems[@i].Response" asp-for="@Model.ChecklistItems[i].Response" value="" required />
                                                        }

                                                    </td>
                                                </tr>
                                            }
                                        </tbody>
                                    </table>
                                </div>
                                <div class="imageUpload">
                                    <!-- Updated drop-area structure -->
                                    <div id="drop-area">
                                        <div id="img-view">
                                            <!-- Upload Icon and Placeholder Text -->
                                            <img id="upload-icon" src="~/img/upload-icon.png" alt="Upload Icon" style="max-width: 100px; height: 100px;">
                                            <div id="placeholder-text">
                                                <p>Drag and drop an image here to upload</p>
                                                <span>Upload any images from desktop</span>
                                            </div>
                                            <!-- The image element that will show the uploaded image -->
                                            <img id="uploaded-image" src="" alt="Uploaded Image" style="display: none;">
                                        </div>
                                        <input type="file" name="file" accept="image/*" id="input-file" hidden>
                                    </div>
                                </div>

                                <div class="text-center">
                                    <button id="cancel-upload" type="button" class="btn btn-danger mt-3" style="display: none;">Cancel Upload</button>
                                    <button id="crop-image-button" type="button" class="btn btn-success mt-3" style="display:none;">Crop Image</button>
                                    <button type="submit" class="mt-3 end-0 btn btn-primary">Submit QC35 Form</button>
                                </div>

                                <canvas id="canvas" style="display:none;"></canvas>

                            </div>
                        </div>
                    </form>
                </div>
            </div>
        </section>
    </main><!-- End #main -->
</div>
<a href="#" class="back-to-top d-flex align-items-center justify-content-center"><i class="bi bi-arrow-up-short"></i></a>

@section Scripts {

    <script>
        document.addEventListener("DOMContentLoaded", function () {
            // DOM elements
            const dropArea = document.getElementById("drop-area");
            const inputFile = document.getElementById("input-file");
            const imageView = document.getElementById("img-view");
            const uploadIcon = document.getElementById("upload-icon");
            const placeholderText = document.getElementById("placeholder-text");
            const uploadedImage = document.getElementById("uploaded-image");
            const cancelUploadButton = document.getElementById("cancel-upload");

            // Initialize Viewer.js on the uploaded image only
            let viewer;

            function initializeViewer() {
                if (viewer) {
                    viewer.destroy(); // Destroy existing Viewer instance if it exists
                }
                viewer = new Viewer(uploadedImage, { // Initialize only on the uploaded image
                    toolbar: true,
                    navbar: false,
                    title: false,
                });
            }

            // Handle drag-and-drop image upload
            dropArea.addEventListener("dragover", function (e) {
                e.preventDefault();
                dropArea.style.borderColor = "#4A90E2"; // Change border color on hover
            });

            dropArea.addEventListener("dragleave", function (e) {
                e.preventDefault();
                dropArea.style.borderColor = "#bbb5ff"; // Reset border color when not dragging
            });

            dropArea.addEventListener("drop", function (e) {
                e.preventDefault();
                dropArea.style.borderColor = "#bbb5ff"; // Reset border color when dropping the file
                inputFile.files = e.dataTransfer.files;
                uploadImage();
            });

            // Handle file upload
            function uploadImage() {
                if (inputFile.files && inputFile.files[0]) {
                    let imgLink = URL.createObjectURL(inputFile.files[0]);

                    // Set the uploaded image src and show the image
                    uploadedImage.src = imgLink;
                    uploadedImage.style.display = "block";

                    // Hide placeholder icon and text
                    uploadIcon.style.display = "none";
                    placeholderText.style.display = "none";

                    // Show the Cancel Upload button
                    cancelUploadButton.style.display = "inline-block";

                    // Re-initialize Viewer.js after setting a new image source
                    initializeViewer();
                }
            }

            // Handle Cancel Upload button click
            cancelUploadButton.addEventListener("click", function () {
                // Reset the input file element
                inputFile.value = "";

                // Hide the uploaded image
                uploadedImage.style.display = "none";
                uploadedImage.src = ""; // Clear the image source

                // Show placeholder icon and text again
                uploadIcon.style.display = "block";
                placeholderText.style.display = "block";

                // Hide the Cancel Upload button
                cancelUploadButton.style.display = "none";

                // Destroy Viewer.js instance as there's no image to view
                if (viewer) {
                    viewer.destroy();
                }
            });

            const dateInput = document.getElementById("reportingYearEnd");
            console.log("Date input: " + dateInput.value);
            // Function to set placeholder if the value is the default date
            function setPlaceholder() {
                if (dateInput.value === "0001-01-01") {
                    dateInput.value = "";
                }
            }

            // Set placeholder on load
            setPlaceholder();

            dateInput.addEventListener("focus", function () {
                dateInput.type = "date"; // Change to date type on focus
                if (dateInput.value === "0001-01-01") {
                    dateInput.value = ""; // Clear default value on focus
                }
            });

            dateInput.addEventListener("blur", function () {
                setPlaceholder();
            });

        });


    </script>
}


