@model PKFAuditManagement.ViewModels.QC35FormViewModel
@using Microsoft.AspNetCore.Mvc.ViewFeatures

<head>
    <link href="~/css/qc35-form-edit.css" rel="stylesheet" />
</head>

<div class="justify-content-center">
    <main id="main" class="main">
        <div class="pagetitle">
            <h1>Form QC35</h1>
        </div><!-- End Page Title -->
        <section class="section">
            <div class="row">
                <div class="col-lg-12">
                    <form asp-action="UpdateQC35Form" asp-controller="QC35Form" method="post" enctype="multipart/form-data">
                        @if (ViewBag.Errors != null)
                        {
                            <ul>
                                @foreach (var error in ViewBag.Errors)
                                {
                                    <li>@error.ErrorMessage</li>
                                }
                            </ul>
                        }
                        else if (ViewBag.ErrorMessage != null)
                        {
                            <span class="alert alert-danger">@ViewBag.ErrorMessage</span>
                        }
                        <div class="card">
                            <div class="card-body">
                                <h5 class="card-title">File Archival Form</h5>
                                <span class="text-danger">* indicates a mandatory field</span>
                                <br><br>
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="_method" value="PUT" /> <!-- Add this line -->

                                <!-- Hidden input for QC35FormID -->
                                <input type="hidden" asp-for="QC35FormID"/>
                                <!-- Hidden input for _method to support PUT operation -->


                                <div class="form-group">
                                    <label asp-for="ClientName">Client Name:<span class="text-danger"> *</span></label>
                                    <div class="input-group">
                                        <select asp-for="ClientName" class="form-control" id="clientSelect">
                                            @if (Model.ClientNames != null && Model.ClientNames.Any())
                                            {
                                                @foreach (var client in Model.ClientNames)
                                                {
                                                    <option value="@client">@client</option>
                                                }
                                            }
                                            else
                                            {
                                                <option disabled>No clients available</option>
                                            }
                                        </select>
                                        <!-- Modal Trigger Button -->
                                        <button type="button" class="btn btn-outline-secondary ms-2" data-bs-toggle="modal" data-bs-target="#clientSearchModal">
                                            <i class="bi bi-search"></i>
                                        </button>
                                        <span asp-validation-for="ClientName" class="text-danger"></span>
                                    </div>
                                </div>
                                <div class="form-group">
                                    <label asp-for="ReportingYearEnd">Reporting Year End:<span class="text-danger"> *</span></label>
                                    <div class="input-group">
                                        <input type="date" class="form-control" asp-for="ReportingYearEnd" id="reportingYearEnd">
                                        <span asp-validation-for="ReportingYearEnd" class="text-danger"></span>
                                    </div>
                                </div>
                                <div class="form-group">
                                    <label asp-for="ClientName">Approved by (Manager):<span class="text-danger"> *</span></label>
                                    <div class="input-group">
                                        <select asp-for="ManagerName" class="form-control">
                                            @foreach (var email in Model.AdminEmails)
                                            {
                                                <option value="@email">@email</option>
                                            }
                                        </select>
                                        <span asp-validation-for="ManagerName" class="text-danger"></span>
                                    </div>
                                </div>
                                <div class="form-group">
                                    <label asp-for="ClientName">Approved by (Partner):<span class="text-danger"> *</span></label>
                                    <div class="input-group">
                                        <select asp-for="PartnerName" class="form-control">
                                            @foreach (var email in Model.AdminEmails)
                                            {
                                                <option value="@email">@email</option>
                                            }
                                        </select>
                                        <span asp-validation-for="PartnerName" class="text-danger"></span>
                                    </div>
                                </div>

                                

                                <div class="table-responsive" id="tableContainer">
                                    <table class="table table-bordered table-striped">
                                        <thead class="table-light" style="background-color: #f8f9fa;">
                                            <tr>
                                                <th class="text-left pl-3 text-uppercase" style="width: 30%;">Checklist - Description</th>
                                                <th class="text-left text-uppercase" style="width: 40%;">Response</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            @for (int i = 0; i < Model.ChecklistItems.Count; i++)
                                            {
                                                <tr class="text-zinc-700 dark:text-zinc-400">
                                                    <td>
                                                        <div>
                                                            <p>@Model.ChecklistItems[i].Description</p>
                                                            <input type="hidden" name="ChecklistItems[@i].QC35ChecklistItemID" value="@Model.ChecklistItems[i].QC35ChecklistItemID" />
                                                        </div>
                                                    </td>
                                                    <td>
                                                        @if (Model.ChecklistItems[i].Description == "Date of Audit Report" ||
                                                       Model.ChecklistItems[i].Description == "Date of approval and confirmation that CaseWare Audit files has been locked down within 60 days from the date of the Audit Report (if applicable). Refer to the screenshot of CaseWare below.")
                                                        {
                                                            <input type="date" class="form-control" name="ChecklistItems[@i].Response" asp-for="@Model.ChecklistItems[i].Response" required />
                                                        }
                                                        else
                                                        {
                                                            <input type="text" class="form-control" name="ChecklistItems[@i].Response" asp-for="@Model.ChecklistItems[i].Response" required />
                                                        }

                                                    </td>
                                                </tr>
                                            }
                                        </tbody>
                                    </table>
                                </div>

                                <div class="imageUpload" style="display: none;">
                                    <div id="drop-area">
                                        <div id="img-view">
                                            <!-- Placeholder content for drag-and-drop area -->
                                            <img id="upload-icon" src="~/img/upload-icon.png" alt="Upload Icon" style="max-width: 100px; height: 100px;">
                                            <div id="placeholder-text">
                                                <p>Drag and drop an image here to upload</p>
                                                <span>Upload any images from desktop</span>
                                            </div>
                                            <!-- The image element that will show the uploaded image -->
                                            <img id="uploaded-image" src="" alt="Uploaded Image" style="display: none;">
                                        </div>
                                        <input type="file" name="file" accept="image/*" id="input-file" hidden>
                                    </div>
                                </div>
                                
                                <!-- Display Existing Image from S3 if Available -->
                                @if (!string.IsNullOrEmpty(Model.ImageFileName))
                                {
                                    <div id="s3ImageContainer" class="imageUpload s3-image-container">
                                        <div id="s3-img-view">
                                            <img id="s3-image" src="@Url.Action("GetImage", "QC35Form", new { key = Model.ImageFileName })" alt="QC35 Form Image" style="max-width:100%; height:auto;">
                                        </div>
                                    </div>
                                }

                                <!-- Include the spinner partial -->
                                @await Html.PartialAsync("_LoadingPartial")

                                <div class="text-center">
                                    <button type="button" id="editImageBtn" class="btn btn-primary mt-3">Edit Image</button>
                                    <button id="cancel-upload" type="button" class="btn btn-danger mt-3" style="display: none;">Cancel Upload</button>
                                    @{
                                        var backUrl = ViewBag.Roles.Contains("Admin") || ViewBag.Roles.Contains("Reviewer")
                                        ? Url.Action("QC35FormApprovalManagement", "QC35Form")
                                        : Url.Action("QC35FormManagement", "QC35Form");
                                    }
                                    <a href="@backUrl" class="mt-3 end-0 btn btn-primary">Back</a>
                                    <button type="submit" class="mt-3 end-0 btn btn-primary" onclick="displayBusyIndicator()">Submit</button>
                                </div>
                            </div>
                        </div>
                  </form>

                </div>
            </div>
        </section>
    </main>
</div>

<!-- Modal for client search display -->
<div class="modal fade" id="clientSearchModal" tabindex="-1" aria-labelledby="clientSearchModalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="clientSearchModalLabel">Search and Select Client</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <!-- Search Input -->
                <input type="text" class="form-control mb-3" id="searchClientInput" placeholder="Search clients..." onkeyup="filterClients()">

                <!-- Client List -->
                <ul class="list-group" id="clientList">
                    @if (Model.ClientNames != null && Model.ClientNames.Any())
                    {
                        @foreach (var client in Model.ClientNames)
                        {
                            <li class="list-group-item" data-client="@client" onclick="selectClient('@client')">
                                @client
                            </li>
                        }
                    }
                    else
                    {
                        <li class="list-group-item disabled">No clients available</li>
                    }
                </ul>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-primary" id="confirmClientBtn" disabled onclick="confirmSelection()">Ok</button>
            </div>
        </div>
    </div>
</div>

<a href="#" class="back-to-top d-flex align-items-center justify-content-center"><i class="bi bi-arrow-up-short"></i></a>

@section Scripts {
    <script src="~/js/qc35-form-edit.js"></script>

    <script>
        function displayBusyIndicator() {
            document.getElementById("loading").style.display = "block";
        }
    </script>
}



