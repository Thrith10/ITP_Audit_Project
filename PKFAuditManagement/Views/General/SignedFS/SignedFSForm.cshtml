@model PKFAuditManagement.ViewModels.SignedFSFormViewModel

<style>
    .form-container {
        padding: 20px;
    }
</style>
<body>
    <main id="main" class="main">
        <div class="pagetitle">
            <h1>Upload Signed Financial Statements (FS)</h1>
        </div><!-- End Page Title -->

        <section class="section dashboard">
            <div class="row">
                <!-- Left side columns -->
                <div class="col-12">
                    <div class="row">
                        <div class="col-xxl-12 col-md-12">
                            <div class="card info-card customers-card">
                                <div class="card-body">
                                    <h5 class="card-title">Upload Signed FS</h5>
                                    <div class="form-container">
                                        <form asp-action="ScheduleEmails" method="post" enctype="multipart/form-data">
                                            <div class="form-group mb-3">
                                                <label asp-for="Client" class="control-label">Client</label>

                                                <div class="d-flex align-items-center">
                                                    <!-- Dropdown -->
                                                    <select asp-for="Client" class="form-control" id="clientSelect" style="flex-grow: 1;">
                                                        @if (Model.ClientNames != null && Model.ClientNames.Any())
                                                        {
                                                            @foreach (var client in Model.ClientNames)
                                                            {
                                                                <option value="@client">@client</option>
                                                            }
                                                        }
                                                        else
                                                        {
                                                            <option disabled>No clients available</option>
                                                        }
                                                    </select>

                                                    <!-- Modal Trigger Button -->
                                                    <button type="button" class="btn btn-outline-secondary ms-2" data-bs-toggle="modal" data-bs-target="#clientSearchModal">
                                                        <i class="bi bi-search"></i>
                                                    </button>
                                                </div>

                                                <span asp-validation-for="Client" class="text-danger"></span>
                                            </div>

                                            <div class="form-group mb-3">
                                                <label asp-for="AuditedReportDate" class="control-label">Audited Report Date</label>
                                                <input asp-for="AuditedReportDate" class="form-control" value="@DateTime.Now.ToString("yyyy-MM-dd")" type="date" required/>
                                                <span asp-validation-for="AuditedReportDate" class="text-danger"></span>
                                            </div>
                                            <div class="form-group mb-3">
                                                <label asp-for="FinancialYearEnd" class="control-label">Financial Year End</label>
                                                <input asp-for="FinancialYearEnd" class="form-control" value="@DateTime.Now.ToString("yyyy-MM-dd")" type="date" required/>
                                                <span asp-validation-for="FinancialYearEnd" class="text-danger"></span>
                                            </div>
                                            <div class="form-group mb-3">
                                                <label asp-for="PartnerEmail" class="control-label">Partner Email</label>
                                                <select asp-for="PartnerEmail" class="form-control" asp-items="@(new SelectList(Model.PartnerEmailOptions))"></select>
                                                <span asp-validation-for="PartnerEmail" class="text-danger"></span>
                                            </div>
                                            <div class="form-group mb-3">
                                                <label asp-for="UserEmail" class="control-label">Your Email</label>
                                                <input asp-for="UserEmail" class="form-control" readonly />
                                                <span asp-validation-for="UserEmail" class="text-danger"></span>
                                            </div>
                                            <div class="form-group mb-3">
                                                <label asp-for="FinancialStatement" class="control-label">Financial Statement (PDF)</label>
                                                <div class="d-flex align-items-center">
                                                    <input asp-for="FinancialStatement" type="file" class="form-control me-2" accept="application/pdf" required/>
                                                    <button type="button" class="btn btn-primary btn-sm preview-doc" style="margin-top: 0;">Preview</button>
                                                </div>
                                                <span asp-validation-for="FinancialStatement" class="text-danger"></span>
                                            </div>
                                            <button type="submit" class="btn btn-primary">Upload</button>
                                        </form>

                                        @section Scripts {
                                            @{
                                                <script src="~/js/signed-fs-creation.js"></script>
                                                await Html.RenderPartialAsync("_ValidationScriptsPartial");
                                            }
                                        }
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div><!-- End Left side columns -->
            </div>
        </section>

    </main><!-- End #main -->
</body>

<!-- Modal for client search display -->
<div class="modal fade" id="clientSearchModal" tabindex="-1" aria-labelledby="clientSearchModalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="clientSearchModalLabel">Search and Select Client</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <!-- Search Input -->
                <input type="text" class="form-control mb-3" id="searchClientInput" placeholder="Search clients..." onkeyup="filterClients()">

                <!-- Client List -->
                <ul class="list-group" id="clientList">
                    @if (Model.ClientNames != null && Model.ClientNames.Any())
                    {
                        @foreach (var client in Model.ClientNames)
                        {
                            <li class="list-group-item" data-client="@client" onclick="selectClient('@client')">
                                @client
                            </li>
                        }
                    }
                    else
                    {
                        <li class="list-group-item disabled">No clients available</li>
                    }
                </ul>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-primary" id="confirmClientBtn" disabled onclick="confirmSelection()">Ok</button>
            </div>
        </div>
    </div>
</div>