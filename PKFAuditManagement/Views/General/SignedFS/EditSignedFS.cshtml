@model PKFAuditManagement.ViewModels.SignedFSFormViewModel

<style>
    .form-container {
        padding: 20px;
    }
</style>
<body>
    <main id="main" class="main">
        <div class="pagetitle">
            <h1>Edit Uploaded Signed Financial Statements (FS)</h1>
        </div><!-- End Page Title -->

        <section class="section dashboard">
            <div class="row">
                <!-- Left side columns -->
                <div class="col-12">
                    <div class="row">
                        <div class="col-xxl-12 col-md-12">
                            <div class="card info-card customers-card">
                                <div class="card-body">
                                    <h5 class="card-title">Edit Uploaded Signed FS</h5>
                                    <div class="form-container">
                                        <form asp-action="UpdateSignedFS" method="post" enctype="multipart/form-data">
                                            <input type="hidden" asp-for="Id" />
                                            <div class="form-group mb-3">
                                                <label asp-for="Client" class="control-label">Client</label>
                                                <select asp-for="Client" class="form-control">
                                                    @if (Model.ClientNames != null && Model.ClientNames.Any())
                                                    {
                                                        @foreach (var client in Model.ClientNames)
                                                        {
                                                            <option value="@client">@client</option>
                                                        }
                                                    }
                                                    else
                                                    {
                                                        <option disabled>No clients available</option>
                                                    }
                                                </select>
                                                <span asp-validation-for="Client" class="text-danger"></span>
                                            </div>
                                            <div class="form-group mb-3">
                                                <label asp-for="AuditedReportDate" class="control-label">Audited Report Date</label>
                                                <input asp-for="AuditedReportDate" class="form-control" type="date" required/>
                                                <span asp-validation-for="AuditedReportDate" class="text-danger"></span>
                                            </div>
                                            <div class="form-group mb-3">
                                                <label asp-for="FinancialYearEnd" class="control-label">Financial Year End</label>
                                                <input asp-for="FinancialYearEnd" class="form-control" type="date" required/>
                                                <span asp-validation-for="FinancialYearEnd" class="text-danger"></span>
                                            </div>
                                            <div class="form-group mb-3">
                                                <label asp-for="PartnerEmail" class="control-label">Partner Email</label>
                                                <select asp-for="PartnerEmail" class="form-control" asp-items="@(new SelectList(Model.PartnerEmailOptions))"></select>
                                                <span asp-validation-for="PartnerEmail" class="text-danger"></span>
                                            </div>
                                            <div class="form-group mb-3">
                                                <label asp-for="UserEmail" class="control-label">Your Email</label>
                                                <input asp-for="UserEmail" class="form-control" readonly />
                                                <span asp-validation-for="UserEmail" class="text-danger"></span>
                                            </div>
                                            <div class="card border border-secondary mt-3">
                                                <div class="card-body">
                                                    <div class="row">
                                                        <div class="col-sm-12">
                                                            <h5 class="card-title">Financial Statement</h5>
                                                        </div>
                                                    </div>

                                                    <table class="table">
                                                        <thead>
                                                            <tr>
                                                                <th>Current Attachment</th>
                                                                <th>Upload New Attachment</th>
                                                                <th>View Uploaded Attachment</th>
                                                            </tr>
                                                        </thead>
                                                        <tbody>
                                                            <tr class="align-middle">
                                                                <td>
                                                                    @if (Model.FinancialStatementFileName != null)
                                                                    {
                                                                        var fileUrl = Url.Content("~/uploads/SignedFS-FinancialStatements/" + Model.FinancialStatementFileName);
                                                                        <a href="@fileUrl" target="_blank">@Model.FinancialStatementFileName</a>
                                                                    }
                                                                </td>
                                                                <td>
                                                                    <input asp-for="FinancialStatement" type="file" class="form-control" accept="application/pdf" />
                                                                    <span asp-validation-for="FinancialStatement" class="text-danger"></span>
                                                                </td>
                                                                <td>
                                                                    <button type="button" class="btn btn-primary btn-sm preview-doc">Preview</button>
                                                                </td>
                                                            </tr>
                                                       </tbody>
                                                    </table>
                                                </div>
                                            </div>
                                            <button type="submit" class="btn btn-primary">Update</button>
                                        </form>

                                        @section Scripts {
                                            @{
                                                <script src="~/js/signed-fs-edit.js"></script>
                                                await Html.RenderPartialAsync("_ValidationScriptsPartial");
                                            }

                                            <script>
                                                $(document).ready(function () {
                                                    var successMessage = '@TempData["SuccessMessage"]';
                                                    if (successMessage) {
                                                        alert(successMessage);
                                                    }
                                                });
                                            </script>
                                        }
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div><!-- End Left side columns -->
            </div>
        </section>

    </main><!-- End #main -->
</body>
