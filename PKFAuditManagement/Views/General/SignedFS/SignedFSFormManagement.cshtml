@using PKFAuditManagement.Models
@model List<SignedFSForm>

<!DOCTYPE html>
<html lang="en">
<body>
    <main id="main" class="main">

        <div class="pagetitle">
            <h1>Manage Signed Financial Statements (FS)</h1>
        </div><!-- End Page Title -->

        <section class="section">
            <div class="row">
                <div class="col-lg-12">

                    <div class="card">
                        <div class="card-body">
                            <div class="row">
                                <div class="col-6">
                                    <h5 class="card-title">Signed FS</h5>
                                </div>
                                <div class="col-6 mt-3 text-end">
                                    <a asp-controller="SignedFSForm" asp-action="ScheduleEmails" class="btn btn-primary btn-lg btn-floating">Create Form</a>
                                </div>
                            </div>
                            <p>As a User/Admin, you will be able to view, edit and upload signed FS.</p>

                            <table class="table datatable" id="engagementTable">
                                <thead>
                                    <tr>
                                        <th>
                                            Client Name
                                        </th>
                                        <th>Partner Email</th>
                                        <th>Audited Report Date</th>
                                        <th>Financial Year End</th>
                                        <th>File Uploaded</th>
                                        <th>Actions</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @if (Model != null)
                                    {
                                        foreach (var engagement in Model)
                                        {
                                            <tr>
                                                <td>@engagement.Client</td>
                                                <td>@engagement.PartnerEmail</td>
                                                <td>@engagement.AuditedReportDate</td>
                                                <td>@engagement.FinancialYearEnd</td>
                                                <td>
                                                    @if (@engagement.FilePath != null)
                                                    {
                                                        var fileUrl = Url.Content("~/uploads/SignedFS-FinancialStatements/" + engagement.FilePath);
                                                        <a href="@fileUrl" target="_blank">@engagement.FilePath</a>
                                                    }
                                                </td>
                                                <td>
                                                    <a asp-action="EditSignedFS" asp-route-id="@engagement.Id" class="btn btn-link">
                                                        <i class="fas fa-edit"></i>
                                                    </a>
                                                    <button type="button" class="btn btn-link text-danger" onclick="confirmDelete('@engagement.Id')">
                                                        <i class="fas fa-trash-alt"></i>
                                                    </button>
                                                </td>
                                            </tr>
                                        }
                                    }
                                    else
                                    {
                                        <tr><td colspan="6">No data found.</td></tr>
                                    }
                                </tbody>
                            </table>

                        </div>
                    </div>

                </div>
            </div>
        </section>

    </main><!-- End #main -->
</body>

</html>

@section Scripts {
    <script src="~/js/signed-fs-delete.js"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/5.15.4/css/all.min.css">
}

